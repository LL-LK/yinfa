page {
  background-color: #F5F9F6;
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 32rpx;
  line-height: 1.6;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

.btn-primary {
  background-color: #2E8B57;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  min-width: 176rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary:active {
  background-color: #267349;
  opacity: 0.9;
}

.btn-outline {
  background-color: transparent;
  color: #2E8B57;
  border: 2rpx solid #2E8B57;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 34rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-danger {
  background-color: #FF8C42;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(46, 139, 87, 0.08);
}

.section-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #2E8B57;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #5A7A5C;
}

.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-green {
  background-color: #E8F5E9;
  color: #2E8B57;
}

.tag-orange {
  background-color: #FFF3E0;
  color: #FF8C42;
}

.tag-red {
  background-color: #FFEBEE;
  color: #D32F2F;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E8F5E9;
  border-top: 4rpx solid #2E8B57;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #5A7A5C;
}
