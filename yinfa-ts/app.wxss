/* ============================================
   银发健康 - 绿色系通用样式
   CSS变量系统 + 通用组件样式
   ============================================ */

/* --------------------------------------------
   一、CSS变量定义 (page层级)
   -------------------------------------------- */
page {
  /* === 绿色系主色调 === */
  --primary: #2E8B57;          /* 海绿色 - 主色 */
  --primary-dark: #246B43;     /* 深绿 - 按下态 */
  --primary-light: #E8F5E9;    /* 浅绿 - 背景色 */
  --primary-rgb: 46, 139, 87;  /* RGB值供透明色用 */

  --accent: #4CAF50;           /* 标准绿 - 强调 */
  --accent-dark: #388E3C;      /* 深绿 - 强调按下 */
  --accent-light: #C8E6C9;     /* 浅绿 - 强调背景 */

  /* === 桂林山水主题色 === */
  --water: #5B9BD5;            /* 漓江蓝 - 水面元素 */
  --water-light: #E8F4FD;      /* 浅蓝 - 水面背景 */
  --water-dark: #3A7CC3;       /* 深蓝 - 水面强调 */
  --gold: #D4A853;             /* 暖金 - 晨曦夕阳 */
  --gold-light: #FFF8E7;       /* 浅金 - 暖色背景 */
  --cloud: #F0F2F0;            /* 云白 - 柔白背景 */

  /* === SOS与危险操作色 === */
  --sos: #FF3B30;              /* 纯红色 - SOS紧急按钮 */
  --sos-dark: #D32F2F;         /* 深红 - SOS按下 */
  --sos-light: #FFEBEE;        /* 浅红 - SOS背景 */

  --danger: #C62828;          /* 红色 - 一般危险 */
  --danger-dark: #B71C1C;      /* 深红 - 危险按下 */
  --danger-light: #FFEBEE;     /* 浅红 - 危险背景 */
  --danger-mild: #1B5E20;     /* 深绿色 - 删除/危险操作（非SOS） */
  --danger-mild-dark: #145218;/* 深绿 - 危险操作按下 */
  --danger-mild-light: #E8F5E9;/* 浅绿 - 危险背景 */

  /* === 成功/警告/信息 === */
  --success: #2E7D32;         /* 深绿 - 成功 */
  --success-dark: #1B5E20;    /* 更深绿 - 成功深色 */
  --success-light: #E8F5E9;   /* 浅绿 - 成功背景 */
  --warning: #F57C00;         /* 橙色 - 警告 */
  --warning-dark: #E65100;    /* 深橙 - 警告深色 */
  --warning-light: #FFF3E0;   /* 浅橙 - 警告背景 */
  --info: #0288D1;            /* 蓝色 - 信息 */
  --info-dark: #01579B;       /* 深蓝 - 信息深色 */
  --info-light: #E1F5FE;      /* 浅蓝 - 信息背景 */

  /* === 背景色 === */
  --bg: #F5F7F5;              /* 浅灰绿 - 页面背景 */
  --bg-card: #FFFFFF;         /* 白色 - 卡片背景 */
  --bg-hover: #E8F5EC;          /* 浅绿 - hover态背景 */
  --bg-overlay: rgba(0, 0, 0, 0.5); /* 遮罩 */
  --bg-mask: rgba(46, 139, 87, 0.08); /* 绿色遮罩 */

  /* === 文字色 === */
  --text-primary: #1B3A2D;    /* 深绿黑 - 主文字 */
  --text-secondary: #4A6B54;  /* 绿灰 - 次要文字 */
  --text-hint: #7A9A7E;       /* 灰绿 - 提示文字 */
  --text-disabled: #B5C4B7;   /* 浅灰绿 - 禁用文字 */
  --text-inverse: #FFFFFF;    /* 白色 - 反色文字 */
  --text-link: #2E8B57;       /* 链接色 */

  /* === 边框色 === */
  --border: #D4E5D8;          /* 浅绿灰 - 边框 */
  --border-light: #E8F0E9;    /* 更浅 - 分割线 */
  --border-focus: #4CAF50;    /* 聚焦边框 */

  /* === 阴影 === */
  --shadow-sm: 0 2rpx 8rpx rgba(46, 139, 87, 0.08);
  --shadow-md: 0 4rpx 16rpx rgba(46, 139, 87, 0.12);
  --shadow-lg: 0 8rpx 32rpx rgba(46, 139, 87, 0.16);
  --shadow-sos: 0 4rpx 20rpx rgba(255, 59, 48, 0.4);
  --shadow-color: rgba(46, 139, 87, 0.1);

  /* === 圆角 === */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-xs: 4rpx;
  --radius-round: 50%;
  --radius-pill: 100rpx;

  /* === 间距 === */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 20rpx;
  --space-lg: 28rpx;
  --space-xl: 36rpx;
  --space-xxl: 48rpx;

  /* === 字体大小 - 普通模式 === */
  --font-xs: 24rpx;           /* 小标签 */
  --font-sm: 28rpx;           /* 辅助文字 */
  --font-md: 32rpx;           /* 正文（默认）*/
  --font-lg: 38rpx;           /* 小标题 */
  --font-xl: 44rpx;           /* 标题 */
  --font-xxl: 52rpx;          /* 大标题 */
  --font-huge: 64rpx;         /* 超大（图标旁）*/

  /* === 行高 === */
  --line-height-tight: 1.2;
  --line-height-normal: 1.5;
  --line-height-relaxed: 1.8;

  /* === 动画 === */
  --transition-fast: 0.15s ease;
  --transition-normal: 0.25s ease;
  --transition-slow: 0.4s ease;

  /* 页面基础样式 */
  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-md);
  color: var(--text-primary);
  line-height: var(--line-height-normal);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  padding-bottom: 120rpx;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

@media (prefers-color-scheme: dark) {
  page {
    --bg: #1a1a2e;
    --bg-card: #16213e;
    --bg-mask: rgba(255,255,255,0.04);
    --bg-overlay: rgba(0,0,0,0.55);
    --text-primary: #e8e8e8;
    --text-secondary: #b0b0b0;
    --text-hint: #888;
    --border: #2a3456;
    --border-light: #1e2a45;
    --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.25);
    --shadow-md: 0 8rpx 24rpx rgba(0,0,0,0.3);
    --shadow-color: rgba(0, 0, 0, 0.15);
    --primary-light: #1a3a2a;
    --accent-light: #1a3a2a;
    --water-light: #1a2a3a;
    --gold-light: #2a2010;
    --cloud: #1a1a2e;
    color: #e8e8e8;
  }
}

/* --------------------------------------------
   二、字号模式切换（银发三档）
   -------------------------------------------- */

/* 小字号模式 */
.font-mode-small {
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-md: 30rpx;
  --font-lg: 34rpx;
  --font-xl: 40rpx;
  --font-xxl: 46rpx;
  --font-huge: 56rpx;
}

/* 大字号模式 */
.font-mode-large {
  --font-xs: 28rpx;
  --font-sm: 34rpx;
  --font-md: 40rpx;
  --font-lg: 46rpx;
  --font-xl: 54rpx;
  --font-xxl: 64rpx;
  --font-huge: 80rpx;
}

/* 极端大字号模式 (≥24px/48rpx) */
.font-mode-huge {
  --font-xs: 48rpx;
  --font-sm: 52rpx;
  --font-md: 56rpx;
  --font-lg: 60rpx;
  --font-xl: 68rpx;
  --font-xxl: 80rpx;
  --font-huge: 96rpx;
  --space-xs: 16rpx;
  --space-sm: 24rpx;
  --space-md: 40rpx;
  --space-lg: 56rpx;
  --space-xl: 72rpx;
  --space-xxl: 96rpx;
}

/* 响应式 - 宽屏适配 */
@media (min-width: 768px) {
  .page {
    max-width: 750rpx;
    margin: 0 auto;
  }
}

/* --------------------------------------------
   三、通用布局组件
   -------------------------------------------- */

/* 页面容器 */
.page {
  min-height: 100vh;
  background: var(--bg);
  padding: var(--space-md);
}

.page-header {
  padding: var(--space-lg) 0;
  margin-bottom: var(--space-md);
}

.page-title {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--text-primary);
  line-height: var(--line-height-tight);
}

.page-subtitle {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: var(--space-xs);
}

/* 通用容器 */
.container {
  padding: var(--space-md);
  min-height: 100vh;
}

.container-safe {
  padding: var(--space-md);
  padding-bottom: env(safe-area-inset-bottom, var(--space-md));
}

/*  Flex工具  */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.flex-shrink-0 { flex-shrink: 0; }

/* --------------------------------------------
   四、卡片组件
   -------------------------------------------- */

.card {
  background: #fff;
  background: var(--bg-card);
  border-radius: 16rpx;
  border-radius: var(--radius-md);
  padding: 28rpx;
  padding: var(--space-lg);
  margin-bottom: 24rpx;
  margin-bottom: var(--space-md);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  box-shadow: var(--shadow-sm);
}

.card:last-child {
  margin-bottom: 0;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-md);
  border-bottom: 1rpx solid var(--border-light);
}

.card-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.card-body {
  font-size: var(--font-md);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
}

.card-footer {
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 1rpx solid var(--border-light);
  display: flex;
  justify-content: flex-end;
  gap: var(--space-sm);
}

/* 卡片变体 */
.card-elevated {
  box-shadow: var(--shadow-md);
}

.card-outlined {
  box-shadow: none;
  border: 2rpx solid var(--border);
}

.card-pressed {
  background: var(--primary-light);
}

.card-scenic {
  background: linear-gradient(to bottom, var(--bg-card) 0%, var(--cloud) 100%);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
  border-left: 6rpx solid var(--water);
}

/* --------------------------------------------
   五、按钮组件
   -------------------------------------------- */

/* 主按钮 - 绿色 */
.btn-primary {
  background: #2E8B57;
  background: var(--primary);
  color: #fff;
  color: var(--text-inverse);
  border-radius: 16rpx;
  border-radius: var(--radius-md);
  padding: 16rpx 56rpx;
  padding: var(--space-sm) var(--space-xl);
  font-size: 36rpx;
  font-size: var(--font-lg);
  font-weight: 600;
  text-align: center;
  display: inline-block;
  min-height: 96rpx;
  line-height: 96rpx;
  border: none;
  transition: all 0.15s ease;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  box-shadow: var(--shadow-sm);
}

.btn-primary:active {
  background: var(--primary-dark);
  transform: scale(0.97);
  box-shadow: none;
}

.btn-primary:disabled {
  background: var(--text-disabled);
  color: var(--bg-card);
  transform: none;
  box-shadow: none;
}

/* 次要按钮 - 绿色边框 */
.btn-secondary {
  background: var(--bg-card);
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: var(--radius-md);
  padding: var(--space-sm) var(--space-xl);
  font-size: var(--font-lg);
  font-weight: 500;
  text-align: center;
  display: inline-block;
  min-height: 96rpx;
  line-height: 96rpx;
  transition: all var(--transition-fast);
}

.btn-secondary:active {
  background: var(--primary-light);
  border-color: var(--primary-dark);
  transform: scale(0.97);
}

/* 幽灵按钮 */
.btn-ghost {
  background: transparent;
  color: var(--primary);
  border: none;
  border-radius: var(--radius-md);
  padding: var(--space-sm) var(--space-md);
  font-size: var(--font-md);
  text-align: center;
  display: inline-block;
  min-height: 72rpx;
  line-height: 72rpx;
}

.btn-ghost:active {
  background: var(--primary-light);
}

/* ===== SOS紧急按钮 - 纯红色 ===== */
.btn-sos {
  background: #FF3B30;
  background: var(--sos);
  color: #fff;
  color: var(--text-inverse);
  border-radius: 24rpx;
  border-radius: var(--radius-lg);
  padding: 24rpx 64rpx;
  padding: var(--space-md) var(--space-xxl);
  font-size: 44rpx;
  font-size: var(--font-xl);
  font-weight: 700;
  text-align: center;
  display: inline-block;
  min-height: 120rpx;
  line-height: 120rpx;
  border: none;
  transition: all 0.15s ease;
  box-shadow: 0 4rpx 16rpx rgba(255, 59, 48, 0.3);
  letter-spacing: 2rpx;
}

.btn-sos:active {
  background: var(--sos-dark);
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(255, 59, 48, 0.3);
}

.btn-sos:disabled {
  background: var(--text-disabled);
  box-shadow: none;
}

/* SOS大按钮（全宽） */
.btn-sos-full {
  width: 100%;
  border-radius: var(--radius-lg);
}

/* ===== 危险操作按钮 - 深绿色（非SOS） ===== */
.btn-danger {
  background: var(--danger-mild);
  color: var(--text-inverse);
  border-radius: var(--radius-md);
  padding: var(--space-sm) var(--space-xl);
  font-size: var(--font-lg);
  font-weight: 600;
  text-align: center;
  display: inline-block;
  min-height: 88rpx;
  line-height: 88rpx;
  border: none;
  transition: all var(--transition-fast);
}

.btn-danger:active {
  background: var(--danger-mild-dark);
  transform: scale(0.97);
}

.btn-danger:disabled {
  background: var(--text-disabled);
  transform: none;
}

/* 危险操作-边框版本 */
.btn-danger-outline {
  background: transparent;
  color: var(--danger-mild);
  border: 2rpx solid var(--danger-mild);
  border-radius: var(--radius-md);
  padding: var(--space-sm) var(--space-xl);
  font-size: var(--font-lg);
  font-weight: 500;
  text-align: center;
  display: inline-block;
  min-height: 88rpx;
  line-height: 88rpx;
  transition: all var(--transition-fast);
}

.btn-danger-outline:active {
  background: var(--danger-mild-light);
}

/* 文字按钮 */
.btn-text {
  background: transparent;
  color: var(--primary);
  border: none;
  padding: var(--space-xs) var(--space-sm);
  font-size: var(--font-md);
  display: inline;
}

.btn-text:active {
  color: var(--primary-dark);
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: var(--space-sm);
}

.btn-group-full {
  display: flex;
  gap: var(--space-sm);
}

.btn-group-full .btn {
  flex: 1;
}

/* --------------------------------------------
   六、标签组件
   -------------------------------------------- */

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-xs);
  font-weight: 600;
  line-height: 1;
}

.tag-primary {
  background: var(--primary-light);
  color: var(--primary);
}

.tag-accent {
  background: var(--accent-light);
  color: var(--accent-dark);
}

.tag-success {
  background: var(--success-light);
  color: var(--success);
}

.tag-warning {
  background: var(--warning-light);
  color: var(--warning);
}

.tag-danger {
  background: var(--sos-light);
  color: var(--sos);
}

.tag-info {
  background: var(--info-light);
  color: var(--info);
}

/* 危险操作标签 - 深绿色 */
.tag-danger-mild {
  background: var(--danger-mild-light);
  color: var(--danger-mild);
}

/* 标签组 */
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

/* --------------------------------------------
   七、输入组件
   -------------------------------------------- */

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 var(--space-md);
  background: var(--bg-card);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  color: var(--text-primary);
  transition: border-color var(--transition-fast);
  box-sizing: border-box;
}

.input:focus {
  border-color: var(--border-focus);
  outline: none;
}

.input::placeholder {
  color: var(--text-hint);
}

.input:disabled {
  background: var(--border-light);
  color: var(--text-disabled);
}

/* 输入框组 */
.input-group {
  margin-bottom: var(--space-md);
}

.input-label {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-xs);
  font-weight: 500;
}

/* --------------------------------------------
   八、空状态组件
   -------------------------------------------- */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xxl) var(--space-lg);
  min-height: 500rpx;
}

.empty-icon {
  font-size: var(--font-huge);
  margin-bottom: var(--space-lg);
  opacity: 0.6;
  line-height: 1;
}

.empty-title {
  font-size: var(--font-xl);
  color: var(--text-secondary);
  font-weight: 600;
  margin-bottom: var(--space-xs);
  text-align: center;
}

.empty-desc {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-bottom: var(--space-xl);
  text-align: center;
  line-height: var(--line-height-relaxed);
}

/* --------------------------------------------
   九、错误状态组件
   -------------------------------------------- */

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xxl) var(--space-lg);
  min-height: 400rpx;
}

.error-icon {
  font-size: var(--font-huge);
  margin-bottom: var(--space-lg);
  opacity: 0.7;
}

.error-title {
  font-size: var(--font-xl);
  color: var(--danger);
  font-weight: 600;
  margin-bottom: var(--space-xs);
}

.error-text {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-bottom: var(--space-xl);
  text-align: center;
}

/* --------------------------------------------
   十、加载状态组件
   -------------------------------------------- */

/* 加载动画 */
@keyframes shimmer {
  0% { opacity: 0.5; }
  50% { opacity: 1; }
  100% { opacity: 0.5; }
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-spinner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xxl) 0;
}

.loading-ring {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: var(--radius-round);
  animation: spin 0.8s linear infinite;
}

.loading-dots {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-round);
  background: var(--primary);
  animation: shimmer 1s ease-in-out infinite;
}

.loading-dot:nth-child(1) { animation-delay: 0s; }
.loading-dot:nth-child(2) { animation-delay: 0.15s; }
.loading-dot:nth-child(3) { animation-delay: 0.3s; }

/* 全局加载遮罩 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-overlay);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

/* --------------------------------------------
   十一、骨架屏组件
   -------------------------------------------- */

.skeleton {
  background: linear-gradient(90deg, var(--border-light) 25%, var(--bg-card) 50%, var(--border-light) 75%);
  background-size: 200% 100%;
  border-radius: var(--radius-sm);
  animation: shimmer 1.5s ease-in-out infinite;
}

.skeleton-text {
  height: 32rpx;
  margin-bottom: var(--space-sm);
  width: 100%;
}

.skeleton-text-short {
  height: 32rpx;
  margin-bottom: var(--space-sm);
  width: 60%;
}

.skeleton-text-long {
  height: 32rpx;
  margin-bottom: var(--space-sm);
  width: 85%;
}

.skeleton-title {
  height: 48rpx;
  margin-bottom: var(--space-md);
  width: 50%;
}

.skeleton-image {
  height: 320rpx;
  border-radius: var(--radius-md);
  margin-bottom: var(--space-md);
}

.skeleton-card {
  height: 200rpx;
  border-radius: var(--radius-md);
  margin-bottom: var(--space-md);
}

.skeleton-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-round);
}

.skeleton-button {
  height: 96rpx;
  border-radius: var(--radius-md);
  width: 200rpx;
}

/* --------------------------------------------
   十二、菜单区块组件
   -------------------------------------------- */

.menu-section {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
}

.menu-section:last-child {
  margin-bottom: 0;
}

.menu-section-title {
  padding: var(--space-md) var(--space-lg) var(--space-sm);
  font-size: var(--font-xs);
  color: var(--text-hint);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-light);
  transition: background var(--transition-fast);
  min-height: 100rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-mask);
}

.menu-item-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: var(--space-md);
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-item-content {
  flex: 1;
  min-width: 0;
}

.menu-item-title {
  font-size: var(--font-lg);
  color: var(--text-primary);
  font-weight: 500;
}

.menu-item-desc {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-top: 4rpx;
}

.menu-item-arrow {
  font-size: var(--font-lg);
  color: var(--text-hint);
  margin-left: var(--space-sm);
}

/* 菜单项-危险操作 */
.menu-item-danger .menu-item-title {
  color: var(--danger-mild);
}

.menu-item-danger .menu-item-icon {
  color: var(--danger-mild);
}

/* --------------------------------------------
   十三、设置区块组件
   -------------------------------------------- */

.settings-section {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
}

.settings-section-title {
  padding: var(--space-md) var(--space-lg) var(--space-sm);
  font-size: var(--font-xs);
  color: var(--text-hint);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg);
  border-bottom: 1rpx solid var(--border-light);
  min-height: 100rpx;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.settings-item-icon {
  width: 56rpx;
  height: 56rpx;
  margin-right: var(--space-md);
  font-size: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: var(--radius-md);
  color: var(--primary);
}

.settings-item-content {
  flex: 1;
  min-width: 0;
}

.settings-item-label {
  font-size: var(--font-lg);
  color: var(--text-primary);
  font-weight: 500;
}

.settings-item-value {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* 设置项-危险操作 */
.settings-item-danger .settings-item-label {
  color: var(--danger-mild);
}

.settings-item-danger .settings-item-icon {
  background: var(--danger-mild-light);
  color: var(--danger-mild);
}

/* --------------------------------------------
   十四、列表组件
   -------------------------------------------- */

.list {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.list-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  border-bottom: 1rpx solid var(--border-light);
  transition: background var(--transition-fast);
  min-height: 96rpx;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background: var(--bg-mask);
}

.list-item-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  margin-right: var(--space-md);
  background: var(--border-light);
  overflow: hidden;
}

.list-item-content {
  flex: 1;
  min-width: 0;
}

.list-item-title {
  font-size: var(--font-lg);
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 4rpx;
}

.list-item-desc {
  font-size: var(--font-sm);
  color: var(--text-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-item-extra {
  margin-left: var(--space-md);
  font-size: var(--font-sm);
  color: var(--text-hint);
}

/* --------------------------------------------
   十五、Banner横幅组件
   -------------------------------------------- */

.banner {
  background: linear-gradient(135deg, #2E8B57 0%, #3A7CC3 100%);
  background: linear-gradient(135deg, var(--primary) 0%, var(--water-dark) 100%);
  border-radius: 24rpx;
  border-radius: var(--radius-lg);
  padding: 36rpx 28rpx;
  padding: var(--space-xl) var(--space-lg);
  color: #fff;
  color: var(--text-inverse);
  margin-bottom: 24rpx;
  margin-bottom: var(--space-md);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
  box-shadow: var(--shadow-md);
  position: relative;
  overflow: hidden;
}

.banner::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.1));
}

.banner-green {
  background: linear-gradient(135deg, #4CAF50, #388E3C);
}

.banner-sunrise {
  background: linear-gradient(135deg, #D4A853 0%, #2E8B57 60%, #3A7CC3 100%);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.banner-sos {
  background: linear-gradient(135deg, #FF3B30, #D32F2F);
  box-shadow: 0 4rpx 16rpx rgba(255, 59, 48, 0.25);
}

.banner-icon {
  font-size: var(--font-huge);
  margin-bottom: var(--space-sm);
  line-height: 1;
}

.banner-title {
  font-size: var(--font-xl);
  font-weight: 700;
  display: block;
  line-height: var(--line-height-tight);
}

.banner-desc {
  font-size: var(--font-sm);
  opacity: 0.9;
  margin-top: var(--space-xs);
  display: block;
  line-height: var(--line-height-normal);
}

/* --------------------------------------------
   十六、分割线与间距
   -------------------------------------------- */

.divider {
  height: 1rpx;
  background: var(--border);
  margin: var(--space-md) 0;
}

.divider-light {
  height: 1rpx;
  background: var(--border-light);
}

.divider-section {
  margin: var(--space-lg) 0;
}

/* --------------------------------------------
   十七、文本工具类
   -------------------------------------------- */

.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-hint { color: var(--text-hint); }
.text-disabled { color: var(--text-disabled); }
.text-inverse { color: var(--text-inverse); }
.text-link { color: var(--text-link); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-danger { color: var(--danger); }
.text-sos { color: var(--sos); }
.text-danger-mild { color: var(--danger-mild); }

.text-xs { font-size: var(--font-xs); }
.text-sm { font-size: var(--font-sm); }
.text-md { font-size: var(--font-md); }
.text-lg { font-size: var(--font-lg); }
.text-xl { font-size: var(--font-xl); }
.text-xxl { font-size: var(--font-xxl); }

.text-bold { font-weight: 700; }
.text-medium { font-weight: 500; }
.text-normal { font-weight: 400; }
.text-center { text-align: center; }
.text-right { text-align: right; }

/* 文本截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* --------------------------------------------
   十八、大按钮（银发专用）
   -------------------------------------------- */

.big-btn {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-sm);
  min-height: 112rpx;
  font-size: var(--font-lg);
  color: var(--text-primary);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.big-btn:last-child {
  margin-bottom: 0;
}

.big-btn:active {
  background: var(--primary-light);
  transform: scale(0.98);
}

.big-btn-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: var(--space-md);
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: var(--radius-md);
  color: var(--primary);
}

.big-btn-content {
  flex: 1;
}

.big-btn-title {
  font-weight: 600;
  line-height: 1.3;
}

.big-btn-desc {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-top: 4rpx;
}

.big-btn-arrow {
  font-size: var(--font-xl);
  color: var(--text-hint);
}

/* 大按钮-危险操作 */
.big-btn-danger {
  background: var(--danger-mild-light);
}

.big-btn-danger:active {
  background: var(--danger-mild);
  color: var(--text-inverse);
}

.big-btn-danger .big-btn-icon {
  background: var(--danger-mild);
  color: var(--text-inverse);
}

/* --------------------------------------------
   十九、徽章组件
   -------------------------------------------- */

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--text-inverse);
}

.badge-primary { background: var(--primary); }
.badge-danger { background: var(--danger); }
.badge-sos { background: var(--sos); }
.badge-success { background: var(--success); }
.badge-warning { background: var(--warning); }

/* 红点 */
.badge-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-round);
  background: var(--sos);
  min-width: 16rpx;
  min-height: 16rpx;
  padding: 0;
}

/* --------------------------------------------
   二十、进度条组件
   -------------------------------------------- */

.progress {
  width: 100%;
  height: 16rpx;
  background: var(--border-light);
  border-radius: var(--radius-pill);
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: var(--primary);
  border-radius: var(--radius-pill);
  transition: width var(--transition-slow);
}

.progress-bar-success { background: var(--success); }
.progress-bar-warning { background: var(--warning); }
.progress-bar-danger { background: var(--danger); }

/* --------------------------------------------
   二十一、开关组件
   -------------------------------------------- */

.switch {
  width: 104rpx;
  height: 64rpx;
  background: var(--border);
  border-radius: var(--radius-pill);
  position: relative;
  transition: background var(--transition-fast);
}

.switch::after {
  content: '';
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  background: var(--bg-card);
  border-radius: var(--radius-round);
  top: 4rpx;
  left: 4rpx;
  transition: transform var(--transition-fast);
  box-shadow: var(--shadow-sm);
}

.switch-active {
  background: var(--primary);
}

.switch-active::after {
  transform: translateX(40rpx);
}

/* --------------------------------------------
   二十二、底部固定区域
   -------------------------------------------- */

.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  padding: var(--space-md) var(--space-lg);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom, 0rpx));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.fixed-bottom-btn {
  width: 100%;
}

/* --------------------------------------------
   二十三、遮罩层
   -------------------------------------------- */

.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-overlay);
  z-index: 999;
}

.mask-green {
  background: rgba(46, 139, 87, 0.3);
}
