<view class="tab-bar">
  <block wx:for="{{list}}" wx:key="index">
    <view class="tab-item" bindtap="switchTab" data-index="{{index}}" data-path="{{item.pagePath}}">
      <image class="tab-icon" src="{{selected === index ? item.selectedIconPath : item.iconPath}}" mode="aspectFit" />
      <text class="tab-label {{selected === index ? 'tab-active' : ''}}" style="color: {{selected === index ? selectedColor : color}}">{{item.text}}</text>
    </view>
    <view wx:if="{{index === 1}}" class="tab-deco">
      <image class="tab-deco-icon" src="/image/tabbar/center-deco.webp" mode="aspectFit" />
    </view>
  </block>
</view>