.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(180deg, rgba(46,139,87,0.18) 0%, rgba(253,255,252,1) 25%, rgba(255,255,255,1) 60%);
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.06);
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(46,139,87,0.12);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 4rpx 0;
  position: relative;
  z-index: 1;
}

.tab-deco {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 100%;
  position: relative;
  z-index: 0;
}

.tab-deco-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(46,139,87,0.15);
  opacity: 0.85;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 2rpx;
}

.tab-label {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 500;
}

.tab-active {
  font-weight: 700;
}