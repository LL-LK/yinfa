# =============================================================================
# yinfa 后端 - 环境变量配置模板
# =============================================================================
# ★ LOCAL DEVELOPMENT: 复制此文件为 .env 填入实际值
# ★ RAILWAY: 手动在 Railway Dashboard Variables 中配置（参考下方说明）
#
# 生成随机密钥:
#   JWT_SECRET=$(openssl rand -hex 32)
#   JWT_APIV3_KEY=$(openssl rand -hex 32)
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库（★ 必须配置）
# -----------------------------------------------------------------------------
# PostgreSQL: 从 Railway PostgreSQL 连接字符串获取
#   格式: postgresql://用户名:密码@主机:5432/数据库名?sslmode=require
# SQLite: 仅用于本地开发（DATABASE_URL 为空时自动回退）
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_RAILWAY_HOST.containers.app:5432/railway?sslmode=require
DB_PATH=./data/app.db

# -----------------------------------------------------------------------------
# JWT 认证（★ 必须配置）
# -----------------------------------------------------------------------------
# 生产环境必须修改！使用 openssl rand -hex 32 生成
JWT_SECRET=PLACEHOLDER_REPLACE_WITH_openssl_rand_hex_32
JWT_EXPIRES_IN=604800

# -----------------------------------------------------------------------------
# AI 服务 lvyou-agi（★ 必须配置）
# -----------------------------------------------------------------------------
# lvyou-agi 部署后填入地址，末尾不要加 /
AGENT_BASE_URL=https://YOUR_LVYOU_AGI_APP.railway.app
AGENT_TIMEOUT=30000

# -----------------------------------------------------------------------------
# 服务器
# -----------------------------------------------------------------------------
PORT=8000
NODE_ENV=production

# -----------------------------------------------------------------------------
# CORS（跨域来源，逗号分隔）
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://your-frontend.railway.app,https://your-miniprogram.servicewechat.com

# -----------------------------------------------------------------------------
# 微信小程序（★ 必须配置，从微信公众平台 https://mp.weixin.qq.com 获取）
# -----------------------------------------------------------------------------
WECHAT_APPID=wxYOURAPPIDHERE
WECHAT_SECRET=YOURWECHATSECRETHERE

# -----------------------------------------------------------------------------
# 微信支付（，开通微信小商店后配置，https://pay.weixin.qq.com）
# -----------------------------------------------------------------------------
WECHAT_MCHID=YOUR_MCHID            # 商户号
WECHAT_APIV3_KEY=PLACEHOLDER_REPLACE_WITH_32CHAR_KEY  # APIv3密钥，32字符
WECHAT_SERIAL_NO=YOUR_SERIAL_NO    # 证书序列号
WECHAT_CERT_PATH=/app/cert/apiclient_cert.pem
WECHAT_KEY_PATH=/app/cert/apiclient_key.pem

# -----------------------------------------------------------------------------
# 日志 & Rate Limiting
# -----------------------------------------------------------------------------
LOG_LEVEL=info
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
