.health {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-inverse);
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.form-section {
  margin: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx 20rpx;
  background: var(--bg);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: var(--font-lg);
  color: var(--text-primary);
  transition: all var(--transition-fast);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--primary);
  background: var(--bg-card);
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx 20rpx;
  background: var(--bg);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: var(--font-md);
  color: var(--text-primary);
  line-height: var(--line-height-relaxed);
  transition: all var(--transition-fast);
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: var(--primary);
  background: var(--bg-card);
}

.submit-btn {
  margin: 20rpx;
  text-align: center;
  padding: 28rpx;
  background: var(--primary);
  color: var(--text-inverse);
  font-size: var(--font-lg);
  font-weight: 700;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.submit-btn:active {
  background: var(--primary-dark);
  transform: scale(0.97);
}

.records-list {
  padding: 0 20rpx;
}

.record-item {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.record-date {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-bottom: 16rpx;
}

.record-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.record-stat {
  background: var(--bg);
  padding: 16rpx 24rpx;
  border-radius: var(--radius-sm);
  min-width: 180rpx;
}

.stat-label {
  display: block;
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-bottom: 6rpx;
}

.stat-value {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.stat-unit {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 400;
}

.record-notes {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-light);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
}

.empty-tip {
  text-align: center;
  padding: 100rpx 20rpx;
  font-size: var(--font-lg);
  color: var(--text-hint);
}
