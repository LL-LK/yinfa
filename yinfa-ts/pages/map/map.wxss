.map-page {
  width: 100%;
  height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
}

.map-view {
  width: 100%;
  height: 55vh;
  flex-shrink: 0;
}

.map-controls {
  position: absolute;
  right: 20rpx;
  top: 30%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  z-index: 10;
}

.map-ctrl-btn {
  width: 80rpx;
  height: 80rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
  transition: all var(--transition-fast);
}

.map-ctrl-btn:active {
  background: var(--primary-light);
  transform: scale(0.93);
}

.ctrl-icon {
  font-size: var(--font-xl);
  line-height: 1;
}

.map-tips {
  position: absolute;
  bottom: 46vh;
  left: 50%;
  transform: translateX(-50%);
  background: var(--bg-overlay);
  color: var(--text-inverse);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: var(--font-xs);
  font-weight: 500;
  box-shadow: var(--shadow-md);
  white-space: nowrap;
  z-index: 10;
}

.scenic-list {
  flex: 1;
  overflow-y: auto;
  background: var(--bg);
  padding: 0 20rpx 20rpx;
}

.scenic-list-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  padding: 24rpx 8rpx 16rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 20rpx;
  font-size: var(--font-sm);
  color: var(--text-hint);
}

.scenic-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.scenic-item:active {
  background: var(--primary-light);
  transform: scale(0.98);
}

.scenic-thumb {
  width: 120rpx;
  height: 90rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  margin-right: 16rpx;
}

.scenic-thumb-fb {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary-light), var(--water-light));
  font-size: 44rpx;
}

.scenic-info {
  flex: 1;
  min-width: 0;
}

.scenic-name {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scenic-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
}

.scenic-price {
  font-size: var(--font-sm);
  font-weight: 700;
}

.has-price {
  color: var(--accent);
}

.free-price {
  color: var(--success);
}

.scenic-distance {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

.scenic-arrow {
  font-size: var(--font-md);
  color: var(--text-hint);
  flex-shrink: 0;
  margin-left: 8rpx;
}