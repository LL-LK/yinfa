.map-page {
  width: 100%;
  height: 100vh;
  position: relative;
}

.map-view {
  width: 100%;
  height: 100%;
}

.loading-text {
  margin-top: 20rpx;
  font-size: var(--font-md);
  color: var(--text-secondary);
}

.map-controls {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  z-index: 10;
}

.map-ctrl-btn {
  width: 80rpx;
  height: 80rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
  transition: all var(--transition-fast);
}

.map-ctrl-btn:active {
  background: var(--primary-light);
  transform: scale(0.93);
}

.ctrl-icon {
  font-size: 36rpx;
  line-height: 1;
}

.map-tips {
  position: absolute;
  bottom: 48rpx;
  left: 50%;
  transform: translateX(-50%);
  background: var(--bg-overlay);
  color: var(--text-inverse);
  padding: 20rpx 40rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-sm);
  font-weight: 500;
  box-shadow: var(--shadow-md);
  white-space: nowrap;
  z-index: 10;
}
