<view class="map-page font-mode-{{fontSizeMode}}">
  <map
    id="myMap"
    class="map-view"
    longitude="{{centerLng}}"
    latitude="{{centerLat}}"
    markers="{{markers}}"
    bindmarkertap="onMarkerTap"
    bindcallouttap="onCalloutTap"
    bindregionchange="onRegionChange"
    scale="{{mapScale}}"
    show-location="{{hasLocation}}"
    show-scale="{{true}}"
    enable-zoom="{{true}}"
    enable-scroll="{{true}}"
  />

  <view class="map-controls">
    <view class="map-ctrl-btn" bindtap="moveToLocation">
      <text class="ctrl-icon">📍</text>
    </view>
    <view class="map-ctrl-btn" bindtap="zoomIn">
      <text class="ctrl-icon">➕</text>
    </view>
    <view class="map-ctrl-btn" bindtap="zoomOut">
      <text class="ctrl-icon">➖</text>
    </view>
  </view>

  <view class="map-tips">
    <text>📍 点击标记查看景点，双指缩放地图</text>
  </view>

  <view class="scenic-list">
    <view class="scenic-list-title">🏔️ 景点列表（点击查看详情）</view>

    <view wx:if="{{scenicProducts.length === 0}}" class="empty-tip">
      <text>暂无景点数据，请检查网络后下拉刷新</text>
    </view>

    <view class="scenic-item" wx:for="{{scenicProducts}}" wx:key="id" bindtap="goScenicDetail" data-id="{{item.id}}">
      <image wx:if="{{item.image_url}}" src="{{item.image_url}}" class="scenic-thumb" mode="aspectFill" lazy-load />
      <view wx:else class="scenic-thumb scenic-thumb-fb">🏔️</view>
      <view class="scenic-info">
        <text class="scenic-name">{{item.name}}</text>
        <view class="scenic-meta">
          <text class="scenic-price {{item.price > 0 ? 'has-price' : 'free-price'}}">{{item.price > 0 ? '¥' + item.price : '免费'}}</text>
          <text class="scenic-distance" wx:if="{{item.distance}}">距{{item.distance}}</text>
        </view>
      </view>
      <text class="scenic-arrow"></text>
    </view>
  </view>
</view>