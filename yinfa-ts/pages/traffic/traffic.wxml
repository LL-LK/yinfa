<view class="traffic">
  <view class="banner">
    <text class="banner-icon">🚦</text>
    <view class="banner-text">
      <text class="banner-title">实时路况</text>
      <text class="banner-desc">桂林道路通行 · 助您畅通出行</text>
    </view>
  </view>

  <view class="t-status-bar">
    <view class="ts-card">
      <view class="ts-status">
        <text class="ts-dot green"></text>
        <text class="ts-num">{{summary.green}}</text>
        <text class="ts-label">畅通</text>
      </view>
    </view>
    <view class="ts-card">
      <view class="ts-status">
        <text class="ts-dot orange"></text>
        <text class="ts-num">{{summary.orange}}</text>
        <text class="ts-label">缓行</text>
      </view>
    </view>
    <view class="ts-card">
      <view class="ts-status">
        <text class="ts-dot red"></text>
        <text class="ts-num">{{summary.red}}</text>
        <text class="ts-label">拥堵</text>
      </view>
    </view>
    <view class="ts-card overall">
      <text class="ts-overall-label">整体</text>
      <text class="ts-overall-val">{{summary.status}}</text>
      <text class="ts-overall-time">{{summary.time}}</text>
    </view>
  </view>

  <view class="road-list">
    <view class="rl-title">🗺️ 主要道路</view>
    <view class="road-item {{item.status === '畅通' ? 'road-green' : item.status === '缓行' ? 'road-orange' : 'road-red'}}" wx:for="{{roads}}" wx:key="index">
      <view class="road-dot {{item.status === '畅通' ? 'dot-green' : item.status === '缓行' ? 'dot-orange' : 'dot-red'}}"></view>
      <view class="road-mid">
        <text class="road-name">{{item.name}}</text>
        <text class="road-desc">{{item.desc}}</text>
      </view>
      <text class="road-speed {{item.status === '畅通' ? 'text-green' : item.status === '缓行' ? 'text-orange' : 'text-red'}}">{{item.speed}}</text>
    </view>
  </view>

  <view class="scenic-parking">
    <view class="sp-title">🅿️ 景区停车</view>
    <view class="sp-grid">
      <view class="sp-item" wx:for="{{scenicTraffic}}" wx:key="index">
        <text class="sp-name">{{item.name}}</text>
        <view class="sp-status {{item.parking === '充足' ? 'sp-full' : item.parking === '紧张' ? 'sp-tight' : 'sp-none'}}">{{item.parking}}</view>
      </view>
    </view>
    <view wx:if="{{scenicSuggest}}" class="sp-suggest">
      <text class="sp-suggest-icon">💡</text>
      <text class="sp-suggest-text">{{scenicSuggest}}</text>
    </view>
  </view>

  <view class="t-tips">
    <view class="t-tips-row" wx:for="{{tips}}" wx:key="index">
      <text class="t-tips-icon">{{item.icon}}</text>
      <text class="t-tips-text">{{item.text}}</text>
    </view>
  </view>
</view>
