<view class="traffic">
  <view class="banner">
    <text class="banner-icon">🚦</text>
    <text class="banner-title">实时路况</text>
    <text class="banner-desc">桂林市区交通快报</text>
  </view>

  <view wx:if="{{loading}}" class="loading-spinner">
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
    <view class="loading-dot"></view>
  </view>

  <view wx:elif="{{error}}" class="error-state">
    <text class="error-icon">😵</text>
    <text class="error-text">路况加载失败</text>
    <text class="btn-primary" bindtap="loadTraffic" style="padding:12rpx 48rpx;font-size:28rpx;min-height:64rpx;line-height:64rpx;">重新加载</text>
  </view>

  <view wx:else>
    <view class="road-list">
      <view class="road-item road-{{item.status === '畅通' ? 'smooth' : item.status === '缓行' ? 'slow' : 'congested'}}"
            wx:for="{{roads}}" wx:key="name">
        <text class="road-icon">{{item.status === '畅通' ? '🟢' : item.status === '缓行' ? '🟡' : '🔴'}}</text>
        <view class="road-info">
          <text class="road-name">{{item.name}}</text>
          <text class="road-detail">{{item.detail}}</text>
        </view>
        <text class="road-status">{{item.status}}</text>
      </view>
    </view>

    <view class="tips-list">
      <view class="tl-item" wx:for="{{tips}}" wx:key="index">
        <text class="tl-icon">{{item.icon}}</text>
        <text class="tl-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="back-btn" bindtap="goBack">
    <text>← 返回交通出行</text>
  </view>
</view>