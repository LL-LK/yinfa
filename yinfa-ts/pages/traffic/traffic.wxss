.traffic {
  background-color: #F5F9F6;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #267349 0%, #2980B9 100%);
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.t-status-bar {
  display: flex;
  margin: 16rpx 20rpx;
  gap: 8rpx;
}

.ts-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 16rpx 6rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ts-status {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ts-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-bottom: 4rpx;
}

.ts-dot.green { background: #2E8B57; }
.ts-dot.orange { background: #FF8C42; }
.ts-dot.red { background: #D32F2F; }

.ts-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.ts-label {
  font-size: 20rpx;
  color: #5A7A5C;
}

.ts-card.overall {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  flex-direction: column;
}

.ts-overall-label {
  font-size: 20rpx;
  color: #5A7A5C;
}

.ts-overall-val {
  font-size: 28rpx;
  font-weight: 700;
  color: #2E8B57;
  margin: 2rpx 0;
}

.ts-overall-time {
  font-size: 18rpx;
  color: #5A7A5C;
}

.road-list {
  background: #FFFFFF;
  margin: 0 20rpx 16rpx;
  border-radius: 16rpx;
  padding: 20rpx 18rpx;
  box-shadow: 0 2rpx 10rpx rgba(46,139,87,0.04);
}

.rl-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #2980B9;
}

.road-item {
  display: flex;
  align-items: center;
  padding: 18rpx 10rpx;
  border-radius: 10rpx;
  margin-bottom: 6rpx;
}

.road-green { background: #F5FAF6; }
.road-orange { background: #FFFBF5; }
.road-red { background: #FFF8F8; }

.road-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.dot-green { background: #2E8B57; }
.dot-orange { background: #FF8C42; }
.dot-red { background: #D32F2F; }

.road-mid {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.road-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.road-desc {
  font-size: 22rpx;
  color: #5A7A5C;
  margin-top: 2rpx;
}

.road-speed {
  font-size: 30rpx;
  font-weight: 700;
}

.text-green { color: #2E8B57; }
.text-orange { color: #FF8C42; }
.text-red { color: #D32F2F; }

.scenic-parking {
  background: #FFFFFF;
  margin: 0 20rpx 16rpx;
  border-radius: 16rpx;
  padding: 20rpx 18rpx;
  box-shadow: 0 2rpx 10rpx rgba(46,139,87,0.04);
}

.sp-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #FF8C42;
}

.sp-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.sp-item {
  width: 47%;
  background: #FAFBFA;
  border-radius: 10rpx;
  padding: 14rpx 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sp-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.sp-status {
  font-size: 20rpx;
  font-weight: 700;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.sp-full { background: #E8F5E9; color: #2E8B57; }
.sp-tight { background: #FFF3E0; color: #FF8C42; }
.sp-none { background: #FFEBEE; color: #D32F2F; }

.sp-suggest {
  display: flex;
  align-items: flex-start;
  background: #E8F5E9;
  border-radius: 10rpx;
  padding: 12rpx 14rpx;
}

.sp-suggest-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.sp-suggest-text {
  font-size: 24rpx;
  color: #2C3E2D;
  flex: 1;
  line-height: 1.5;
}

.t-tips {
  background: #FFFFFF;
  margin: 0 20rpx;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(46,139,87,0.04);
}

.t-tips-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.t-tips-row:last-child {
  border-bottom: none;
}

.t-tips-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
}

.t-tips-text {
  font-size: 26rpx;
  color: #2C3E2D;
}
