.traffic {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-inverse);
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.road-list {
  padding: 20rpx;
}

.road-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.road-item:active {
  transform: scale(0.98);
}

.road-icon {
  font-size: 48rpx;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  border-radius: var(--radius-round);
  flex-shrink: 0;
}

.road-info {
  flex: 1;
  min-width: 0;
}

.road-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.road-detail {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
}

.road-status {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-sm);
  font-weight: 700;
  flex-shrink: 0;
}

.road-status.smooth {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.road-status.slow {
  background: #FFF8E1;
  color: var(--warning-dark);
}

.road-status.congested {
  background: var(--danger-light);
  color: var(--danger);
}

.tips-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 0 20rpx 20rpx;
}

.tl-item {
  flex: 1;
  min-width: calc(50% - 10rpx);
  background: var(--bg-card);
  padding: 20rpx;
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tl-icon {
  font-size: 32rpx;
}

.tl-text {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.back-btn {
  margin: 0 20rpx 20rpx;
  text-align: center;
  padding: 28rpx;
  background: var(--primary);
  color: var(--text-inverse);
  font-size: var(--font-lg);
  font-weight: 700;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.back-btn:active {
  background: var(--primary-dark);
  transform: scale(0.97);
}
