.traffic {
  background-color: #F5F9F6;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 40rpx 30rpx;
}

.banner-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.summary-card {
  background-color: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.summary-status {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.summary-icon {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.summary-text {
  display: flex;
  flex-direction: column;
}

.summary-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.summary-time {
  font-size: 24rpx;
  color: #5A7A5C;
  margin-top: 4rpx;
}

.summary-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #E8F5E9;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
}

.stat-num.green { color: #2E8B57; }
.stat-num.orange { color: #FF8C42; }
.stat-num.red { color: #D32F2F; }

.stat-label {
  font-size: 24rpx;
  color: #5A7A5C;
  margin-top: 4rpx;
}

.road-list {
  background-color: #FFFFFF;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.road-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.road-item:last-child {
  border-bottom: none;
}

.road-status {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.status-green { background-color: #2E8B57; }
.status-orange { background-color: #FF8C42; }
.status-red { background-color: #D32F2F; }

.road-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.road-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.road-desc {
  font-size: 24rpx;
  color: #5A7A5C;
  margin-top: 2rpx;
}

.road-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.road-speed {
  font-size: 30rpx;
  font-weight: 700;
}

.road-status-text {
  font-size: 24rpx;
}

.text-green { color: #2E8B57; }
.text-orange { color: #FF8C42; }
.text-red { color: #D32F2F; }

.scenic-traffic {
  background-color: #FFFFFF;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.scenic-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.scenic-item:last-child {
  border-bottom: none;
}

.scenic-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.scenic-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.scenic-body {
  display: flex;
  flex-direction: column;
}

.scenic-desc {
  font-size: 26rpx;
  color: #5A7A5C;
  line-height: 1.5;
}

.scenic-suggest {
  display: flex;
  align-items: flex-start;
  margin-top: 10rpx;
  padding: 12rpx 16rpx;
  background-color: #E8F5E9;
  border-radius: 8rpx;
}

.suggest-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.suggest-text {
  font-size: 24rpx;
  color: #2C3E2D;
  flex: 1;
  line-height: 1.5;
}

.tips-card {
  background-color: #FFFFFF;
  margin: 0 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.tips-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E2D;
  display: block;
  margin-bottom: 20rpx;
}

.tips-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.tip-block {
  width: 48%;
  background-color: #FAFBFA;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tip-block-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.tip-block-text {
  font-size: 24rpx;
  color: #2C3E2D;
  text-align: center;
  line-height: 1.5;
}
