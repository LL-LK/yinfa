.traffic {
  background-color: #F5F9F6;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #267349 0%, #2980B9 100%);
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.weather-bar {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  margin: 0 20rpx 16rpx;
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
}

.wb-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wb-icon {
  font-size: 32rpx;
}

.wb-text {
  font-size: 24rpx;
  color: #2C3E2D;
  font-weight: 600;
}

.slippery-warning { background: #FFF3E0; border-radius: 8rpx; padding: 4rpx 12rpx; }
.slippery-danger { background: #FFEBEE; border-radius: 8rpx; padding: 4rpx 12rpx; }
.slippery-warning .wb-text { color: #FF9800; }
.slippery-danger .wb-text { color: #D32F2F; }

.disclaimer {
  background: #FFF9E6;
  margin: 0 20rpx 12rpx;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  text-align: center;
}

.disclaimer text {
  font-size: 22rpx;
  color: #8B6914;
}

.t-status-bar {
  display: flex;
  margin: 16rpx 20rpx;
}

.ts-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 16rpx 6rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 4rpx;
}

.ts-status {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ts-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-bottom: 4rpx;
}

.ts-dot.green { background: #2E8B57; }
.ts-dot.orange { background: #FF8C42; }
.ts-dot.red { background: #D32F2F; }

.ts-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.ts-label {
  font-size: 20rpx;
  color: #5A7A5C;
}

.ts-card.overall {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  flex-direction: column;
}

.ts-overall-label {
  font-size: 20rpx;
  color: #5A7A5C;
}

.ts-overall-val {
  font-size: 28rpx;
  font-weight: 700;
  color: #2E8B57;
  margin: 2rpx 0;
}

.ts-overall-time {
  font-size: 18rpx;
  color: #5A7A5C;
}

.road-list {
  background: #FFFFFF;
  margin: 0 20rpx 16rpx;
  border-radius: 16rpx;
  padding: 20rpx 18rpx;
  box-shadow: 0 2rpx 10rpx rgba(46,139,87,0.04);
}

.rl-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #2980B9;
}

.road-item {
  display: flex;
  align-items: center;
  padding: 18rpx 10rpx;
  border-radius: 10rpx;
  margin-bottom: 6rpx;
}

.road-smooth { background: #F5FAF6; }
.road-slow { background: #FFFBF5; }
.road-congested { background: #FFF8F8; }

.road-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.dot-smooth { background: #2E8B57; }
.dot-slow { background: #FF8C42; }
.dot-congested { background: #D32F2F; }

.road-mid {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.road-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.road-desc {
  font-size: 22rpx;
  color: #5A7A5C;
  margin-top: 2rpx;
}

.road-speed {
  font-size: 30rpx;
  font-weight: 700;
}

.text-smooth { color: #2E8B57; }
.text-slow { color: #FF8C42; }
.text-congested { color: #D32F2F; }

.t-tips {
  background: #FFFFFF;
  margin: 0 20rpx;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(46,139,87,0.04);
}

.t-tips-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.t-tips-row:last-child {
  border-bottom: none;
}

.t-tips-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
}

.t-tips-text {
  font-size: 26rpx;
  color: #2C3E2D;
}
