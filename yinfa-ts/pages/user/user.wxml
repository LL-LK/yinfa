<view class="user">
  <view class="user-header">
    <view class="avatar-box">
      <text class="avatar-emoji">👴</text>
    </view>
    <text class="user-name">桂林游客</text>
    <text class="user-id">尊贵的银发旅行者</text>
    <view class="user-stats">
      <view class="stat">
        <text class="stat-num">3</text>
        <text class="stat-label">游览景点</text>
      </view>
      <view class="stat">
        <text class="stat-num">5</text>
        <text class="stat-label">出行天数</text>
      </view>
      <view class="stat">
        <text class="stat-num">86</text>
        <text class="stat-label">安全分</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goOrders">
      <text class="menu-icon">📋</text>
      <text class="menu-name">我的订单</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goAddress">
      <text class="menu-icon">📍</text>
      <text class="menu-name">地址管理</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goScenic">
      <text class="menu-icon">🏔️</text>
      <text class="menu-name">我的收藏</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goSafety">
      <text class="menu-icon">🛡️</text>
      <text class="menu-name">安全设置</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="callHelp">
      <text class="menu-icon">🆘</text>
      <text class="menu-name">一键求助</text>
      <text class="menu-desc">桂林旅游服务热线</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-name">关于桂林银发旅游</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
