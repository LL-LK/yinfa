<view class="user font-mode-{{fontSizeMode}}">
  <view class="user-header">
    <view class="avatar-box">
      <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="avatar-img" mode="aspectFill" />
      <text wx:else class="avatar-emoji">{{isLoggedIn ? '👴' : '🔐'}}</text>
    </view>

    <text class="user-name">{{nickname}}</text>

    <block wx:if="{{isLoggedIn}}">
      <text class="user-id">{{phone ? '已绑定手机' : '桂林银发旅行者'}}</text>
      <view class="btn-logout" bindtap="doLogout">退出登录</view>
    </block>

    <block wx:else>
      <text class="user-subtitle">点击登录，享受更多服务</text>
      <view class="btn-login" bindtap="doLogin">微信一键登录</view>
    </block>

    <view class="user-stats">
      <view class="stat" bindtap="tapMenu" data-id="favorites">
        <text class="stat-num">{{favoriteCount}}</text>
        <text class="stat-label">收藏景点</text>
      </view>
      <view class="stat" bindtap="tapMenu" data-id="orders">
        <text class="stat-num">{{orderCount}}</text>
        <text class="stat-label">我的订单</text>
      </view>
      <view class="stat" bindtap="toggleVoice">
        <text class="stat-num">{{voiceEnabled ? '开' : '关'}}</text>
        <text class="stat-label">语音提示</text>
      </view>
    </view>
  </view>

  <view class="sos-section" bindtap="sendSOS">
    <view class="sos-icon">🆘</view>
    <view class="sos-text">
      <text class="sos-title">紧急求助</text>
      <text class="sos-desc">遇到危险，一键求助家人和救援</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" wx:for="{{menuItems}}" wx:key="id" bindtap="tapMenu" data-id="{{item.id}}">
      <text class="menu-icon">{{item.icon}}</text>
      <text class="menu-name">{{item.name}}</text>
      <text class="menu-badge" wx:if="{{item.badge && favoriteCount > 0}}">{{favoriteCount}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-title">语音提示</view>
    <view class="voice-switch" bindtap="toggleVoice">
      <text>{{voiceEnabled ? '✅ 已开启（点击关闭）' : '❌ 已关闭（点击开启）'}}</text>
      <text class="voice-hint">开启后每次点击按钮都会语音播报，方便老人使用</text>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-title">语言辅助</view>
    <view class="lang-assist-switch" bindtap="toggleLangAssist">
      <switch checked="{{langAssistEnabled}}" color="#2E8B57" />
      <view class="lang-assist-content">
        <text class="lang-assist-title">{{langAssistEnabled ? '✅ 已开启' : '❌ 已关闭'}}</text>
        <text class="lang-assist-hint">开启后提供多语言翻译和语音朗读辅助功能</text>
      </view>
    </view>
    <view wx:if="{{langAssistEnabled}}" class="lang-options">
      <view class="lang-option {{langClassZh}}" bindtap="setLangAssist" data-lang="zh">
        <text class="lang-name">中文</text>
      </view>
      <view class="lang-option {{langClassEn}}" bindtap="setLangAssist" data-lang="en">
        <text class="lang-name">English</text>
      </view>
      <view class="lang-option {{langClassJa}}" bindtap="setLangAssist" data-lang="ja">
        <text class="lang-name">日本語</text>
      </view>
      <view class="lang-option {{langClassKo}}" bindtap="setLangAssist" data-lang="ko">
        <text class="lang-name">한국어</text>
      </view>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-title">字体大小</view>
    <view class="font-size-options">
      <view class="font-option {{fontSizeMode === 'small' ? 'active' : ''}}" bindtap="setFontSize" data-mode="small">标准</view>
      <view class="font-option {{fontSizeMode === 'normal' ? 'active' : ''}}" bindtap="setFontSize" data-mode="normal">较大</view>
      <view class="font-option {{fontSizeMode === 'large' ? 'active' : ''}}" bindtap="setFontSize" data-mode="large">超大</view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-name">关于桂林银发旅游</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>