.user {
  background-color: #F5F9F6;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.user-header {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 60rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-box {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255,255,255,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: 3rpx solid rgba(255,255,255,0.5);
}

.avatar-emoji {
  font-size: 56rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-top: 30rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}

.menu-section {
  background-color: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #F8FAF8;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-name {
  flex: 1;
  font-size: 30rpx;
  color: #2C3E2D;
  font-weight: 600;
}

.menu-desc {
  font-size: 24rpx;
  color: #5A7A5C;
  margin-right: 8rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCC;
}

.menu-badge {
  background-color: #FF4757;
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.sos-section {
  background: linear-gradient(135deg, #FF4757 0%, #FF6B6B 100%);
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(255,71,87,0.3);
}

.sos-section:active {
  opacity: 0.9;
}

.sos-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.sos-text {
  flex: 1;
}

.sos-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.sos-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.settings-section {
  background-color: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.settings-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E2D;
  margin-bottom: 24rpx;
}

.font-size-options {
  display: flex;
  justify-content: space-around;
}

.font-option {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 16rpx;
  background-color: #F5F9F6;
  margin: 0 8rpx;
  border: 2rpx solid transparent;
}

.font-option.active {
  background-color: #E8F5EC;
  border-color: #2E8B57;
}

.font-option text {
  font-size: 28rpx;
  color: #2C3E2D;
  font-weight: 500;
}
