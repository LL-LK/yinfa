.user {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.header-card {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 48rpx 40rpx 80rpx;
  display: flex;
  align-items: center;
}

.avatar-box {
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-round);
  overflow: hidden;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
  border: 4rpx solid rgba(255,255,255,0.35);
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 60rpx;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-inverse);
  margin-bottom: 6rpx;
}

.user-tip {
  font-size: var(--font-sm);
  color: rgba(255,255,255,0.7);
}

.user-id {
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 4rpx;
}

.sos-section {
  margin: -40rpx 20rpx 24rpx;
  position: relative;
  z-index: 10;
}

.sos-btn {
  width: 100%;
  padding: 32rpx;
  text-align: center;
  background: var(--danger);
  color: var(--text-inverse);
  font-size: var(--font-xl);
  font-weight: 700;
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 32rpx rgba(211, 47, 47, 0.35);
  transition: all var(--transition-fast);
}

.sos-btn:active {
  background: var(--danger-dark);
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(211, 47, 47, 0.25);
}

.sos-sub {
  text-align: center;
  margin-top: 10rpx;
  font-size: var(--font-xs);
  color: var(--text-hint);
}

.section {
  margin: 0 20rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.section-title {
  padding: 28rpx 28rpx 16rpx;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-top: 1rpx solid var(--border-light);
  transition: all var(--transition-fast);
}

.menu-item:active {
  background: var(--bg-mask);
}

.mi-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.mi-icon {
  font-size: 44rpx;
  width: 72rpx;
  text-align: center;
}

.mi-text {
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--text-primary);
}

.mi-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.mi-badge {
  font-size: var(--font-xs);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  font-weight: 600;
}

.mi-badge.danger {
  background: var(--danger-light);
  color: var(--danger);
}

.mi-badge.primary {
  background: var(--primary-light);
  color: var(--primary);
}

.mi-arrow {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

.mi-val {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

.settings-section {
  margin: 0 20rpx 28rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-top: 1rpx solid var(--border-light);
}

.setting-item:first-child {
  border-top: none;
}

.si-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.si-icon {
  font-size: 44rpx;
  width: 72rpx;
  text-align: center;
}

.si-text {
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--text-primary);
}

.switch {
  width: 96rpx;
  height: 52rpx;
}

.font-range {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.font-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-round);
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  transition: all var(--transition-fast);
}

.font-btn:active {
  background: var(--bg-hover);
  border-color: var(--primary);
}

.font-size-label {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  min-width: 140rpx;
  text-align: center;
}

.logout-section {
  margin: 0 20rpx 28rpx;
}

.logout-btn {
  width: 100%;
  padding: 28rpx;
  text-align: center;
  background: var(--bg-card);
  color: var(--danger);
  font-size: var(--font-lg);
  font-weight: 600;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--danger-light);
  transition: all var(--transition-fast);
}

.logout-btn:active {
  background: var(--danger-light);
}
