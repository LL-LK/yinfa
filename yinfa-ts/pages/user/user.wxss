.user {
  padding: 15px;
}

.user-info {
  background: linear-gradient(135deg, #ff6b00, #ff8c42);
  border-radius: 15px;
  padding: 30px;
  display: flex;
  align-items: center;
  margin-bottom: 15px;
}

.avatar {
  width: 80px;
  height: 80px;
  background-color: rgba(255,255,255,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  margin-right: 20px;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 20px;
  font-weight: bold;
  color: white;
  margin-bottom: 5px;
}

.user-phone {
  font-size: 14px;
  color: rgba(255,255,255,0.8);
}

.user-menu {
  background-color: white;
  border-radius: 15px;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 15px;
  border-bottom: 1px solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 24px;
  margin-right: 15px;
}

.menu-text {
  flex: 1;
  font-size: 16px;
}

.menu-arrow {
  color: #999;
  font-size: 20px;
}