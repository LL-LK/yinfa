.user {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.user-header {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 60rpx 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-box {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  overflow: hidden;
}

.avatar-emoji {
  font-size: 56rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-inverse);
  margin-bottom: 4rpx;
}

.user-id {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 6rpx;
}

.user-subtitle {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 20rpx;
}

.btn-login {
  background: rgba(255, 255, 255, 0.2);
  color: var(--text-inverse);
  border: 2rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 40rpx;
  padding: 14rpx 64rpx;
  font-size: var(--font-md);
  font-weight: 600;
  transition: all var(--transition-fast);
}

.btn-login:active {
  background: rgba(255, 255, 255, 0.35);
  transform: scale(0.96);
}

.btn-logout {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.55);
  margin-bottom: 8rpx;
  padding: 4rpx 0;
}

.btn-logout:active {
  color: rgba(255, 255, 255, 0.9);
}

.user-stats {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
}

.stat-num {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-inverse);
}

.stat-label {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4rpx;
}

.sos-section {
  margin: var(--space-md) 20rpx;
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  border-left: 6rpx solid var(--sos);
  transition: all var(--transition-fast);
}

.sos-section:active {
  background: var(--sos-light);
  transform: scale(0.98);
}

.sos-icon {
  font-size: 48rpx;
  margin-right: var(--space-md);
}

.sos-text {
  display: flex;
  flex-direction: column;
}

.sos-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.sos-desc {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-top: 4rpx;
}

.menu-section {
  margin: 0 20rpx var(--space-md);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  border-bottom: 1rpx solid var(--border-light);
  transition: background var(--transition-fast);
  min-height: 100rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-mask);
}

.menu-icon {
  font-size: var(--font-xl);
  margin-right: 20rpx;
  width: 56rpx;
  text-align: center;
  flex-shrink: 0;
}

.menu-name {
  flex: 1;
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--text-primary);
}

.menu-badge {
  font-size: var(--font-xs);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-pill);
  background: var(--sos);
  color: var(--text-inverse);
  font-weight: 600;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

.settings-section {
  margin: 0 20rpx var(--space-md);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  box-shadow: var(--shadow-sm);
}

.settings-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-md);
}

.voice-switch {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  background: var(--cloud);
  border-radius: 12rpx;
  font-size: var(--font-sm);
  color: var(--text-primary);
  transition: all var(--transition-fast);
}

.voice-switch:active {
  background: var(--primary-light);
}

.voice-hint {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-top: 8rpx;
}

.lang-assist-switch {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: var(--cloud);
  border-radius: 12rpx;
  transition: all var(--transition-fast);
}

.lang-assist-switch:active {
  background: var(--primary-light);
}

.lang-assist-content {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.lang-assist-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.lang-assist-hint {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-top: 4rpx;
}

.lang-options {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.lang-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  background: var(--bg);
  border: 2rpx solid var(--border);
  transition: all var(--transition-fast);
}

.lang-option:active {
  transform: scale(0.95);
  background: var(--primary-light);
}

.lang-active {
  background: var(--primary-light);
  border-color: var(--primary);
  font-weight: 700;
  color: var(--primary-dark);
  font-size: var(--font-sm);
}

.font-size-options {
  display: flex;
  gap: 16rpx;
}

.font-option {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background: var(--bg);
  font-size: var(--font-md);
  color: var(--text-secondary);
  border: 2rpx solid var(--border);
  transition: all var(--transition-fast);
}

.font-option.active {
  background: var(--primary);
  color: var(--text-inverse);
  font-weight: 600;
  border-color: var(--primary-dark);
  box-shadow: var(--shadow-sm);
}

.font-option:active {
  transform: scale(0.96);
}