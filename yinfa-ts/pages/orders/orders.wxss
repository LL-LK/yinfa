.orders {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-inverse);
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.orders-list {
  padding: 20rpx;
}

.order-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.oc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.oc-id {
  font-size: var(--font-sm);
  color: var(--text-hint);
}

.oc-status {
  font-size: var(--font-sm);
  font-weight: 700;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-pill);
}

.oc-status.pending {
  background: var(--warning-light);
  color: var(--warning-dark);
}

.oc-status.paid {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.oc-status.shipped {
  background: var(--info-light);
  color: var(--info-dark);
}

.oc-status.completed {
  background: var(--success-light);
  color: var(--success-dark);
}

.oc-status.cancelled {
  background: var(--danger-light);
  color: var(--danger);
}

.oc-items {
  padding: 20rpx 28rpx;
}

.oc-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.oc-item:last-child {
  border-bottom: none;
}

.oci-image {
  width: 140rpx;
  height: 110rpx;
  border-radius: var(--radius-sm);
  background: var(--border-light);
  flex-shrink: 0;
}

.oci-img {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-sm);
}

.oci-info {
  flex: 1;
}

.oci-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.oci-price {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--accent);
  margin-top: 8rpx;
}

.oci-qty {
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-top: 4rpx;
}

.oc-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: var(--bg);
}

.oc-total {
  font-size: var(--font-md);
  color: var(--text-secondary);
}

.oc-total text {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--accent);
}

.oc-action {
  padding: 16rpx 36rpx;
  background: var(--primary);
  color: var(--text-inverse);
  font-size: var(--font-md);
  font-weight: 600;
  border-radius: var(--radius-pill);
  transition: all var(--transition-fast);
}

.oc-action:active {
  background: var(--primary-dark);
  transform: scale(0.97);
}

.empty-orders {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-orders .empty-icon {
  font-size: 100rpx;
  opacity: 0.3;
  margin-bottom: 16rpx;
}

.empty-orders .empty-text {
  font-size: var(--font-lg);
  color: var(--text-hint);
}
