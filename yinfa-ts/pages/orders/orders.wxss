.orders {
  background-color: #F5F9F6;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 40rpx 30rpx;
}

.banner-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.order-list {
  padding: 20rpx 24rpx;
}

.order-item {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-no {
  font-size: 24rpx;
  color: #5A7A5C;
}

.order-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-bottom: 16rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #E8F5E9;
}

.order-row {
  display: flex;
  gap: 20rpx;
}

.order-date {
  font-size: 26rpx;
  color: #5A7A5C;
}

.order-people {
  font-size: 26rpx;
  color: #5A7A5C;
}

.order-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF8C42;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #5A7A5C;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}
