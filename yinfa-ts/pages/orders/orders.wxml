<view class="orders">
  <view class="banner">
    <text class="banner-title">我的订单</text>
    <text class="banner-desc">桂林之旅·轻松管理</text>
  </view>

  <view wx:if="{{orders.length > 0}}" class="order-list">
    <view class="order-item" wx:for="{{orders}}" wx:key="index" bindtap="readOrder" data-index="{{index}}">
      <view class="order-header">
        <text class="order-no">订单号: {{item.orderNo}}</text>
        <view class="order-status tag-green">{{item.statusText}}</view>
      </view>
      <view class="order-title">{{item.title}}</view>
      <view class="order-footer">
        <view class="order-row">
          <text class="order-date">📅 {{item.date}}</text>
          <text class="order-people">👥 {{item.people}}人</text>
        </view>
        <text class="order-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>

  <view wx:else class="empty">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无订单</text>
    <text class="empty-sub">快去探索桂林美景吧</text>
  </view>
</view>
