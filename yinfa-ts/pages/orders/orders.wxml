<view class="orders">
  <view class="order-create" wx:if="{{cartItems.length > 0}}">
    <view class="create-title">购物车商品</view>
    <view class="cart-summary" wx:for="{{cartItems}}" wx:key="id">
      <text>{{item.name}} x {{item.quantity}}</text>
    </view>
    <view class="create-btn" bindtap="createOrder">提交订单</view>
  </view>

  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view class="order-item" wx:for="{{orders}}" wx:key="id">
      <view class="order-header">
        <text class="order-no">订单号: {{item.order_no}}</text>
        <text class="order-status">{{item.status === 'pending' ? '待支付' : item.status === 'paid' ? '已支付' : '已完成'}}</text>
      </view>
      <view class="order-items">
        <view class="order-product" wx:for="{{item.items}}" wx:key="id" wx:for-item="product">
          <image src="{{product.product.image_url}}" class="product-img" mode="aspectFill" />
          <view class="product-info">
            <text class="product-name">{{product.product.name}}</text>
            <text class="product-price">¥{{product.unit_price}} x {{product.quantity}}</text>
          </view>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-total">合计: ¥{{item.total_price}}</text>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{orders.length === 0 && cartItems.length === 0}}">
    <text>暂无订单</text>
  </view>
</view>