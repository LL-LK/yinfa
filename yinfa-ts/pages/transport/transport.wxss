.transport {
  background-color: #F5F9F6;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 40rpx 30rpx;
}

.banner-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.transport-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 24rpx;
  justify-content: space-between;
}

.transport-card {
  width: 48%;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.transport-icon-box {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.transport-emoji {
  font-size: 48rpx;
}

.transport-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-bottom: 8rpx;
}

.transport-desc {
  font-size: 24rpx;
  color: #5A7A5C;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.transport-btn {
  font-size: 26rpx;
  padding: 12rpx 32rpx;
}

.tips-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 0 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.tips-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E2D;
  display: block;
  margin-bottom: 16rpx;
}

.tips-item {
  font-size: 28rpx;
  color: #5A7A5C;
  line-height: 1.8;
  display: block;
}
