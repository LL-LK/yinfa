.transport {
  background: var(--bg);
  padding-bottom: 40rpx;
}

.quick-btns {
  display: flex;
  margin: 20rpx;
  gap: 16rpx;
}

.qb-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 28rpx 20rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.qb-btn:active {
  background: var(--bg-hover);
  transform: scale(0.97);
}

.qb-icon {
  font-size: var(--font-xl);
}

.qb-label {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.mode-list {
  padding: 0 20rpx;
}

.mode-item {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.mi-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.mi-icon {
  font-size: var(--font-huge);
  margin-right: 20rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: var(--radius-md);
}

.mi-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.mi-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.mi-badge {
  font-size: var(--font-xs);
  padding: 6rpx 14rpx;
  background: var(--accent-light);
  color: var(--accent-dark);
  border-radius: var(--radius-pill);
  font-weight: 600;
}

.mi-desc {
  display: block;
  font-size: var(--font-md);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
  margin-bottom: 12rpx;
  margin-left: 100rpx;
}

.mi-tips {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-left: 100rpx;
  padding: 12rpx 16rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
}

.tips-list {
  background: var(--bg-card);
  margin: 0 20rpx;
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  box-shadow: var(--shadow-sm);
}

.tl-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.tl-item:last-child {
  border-bottom: none;
}

.tl-icon {
  font-size: var(--font-xl);
  margin-right: 16rpx;
}

.tl-text {
  flex: 1;
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}