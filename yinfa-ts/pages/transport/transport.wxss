.transport {
  background-color: #F5F9F6;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon-deco {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.transport-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 20rpx;
  justify-content: space-between;
}

.transport-card {
  width: 48%;
  background-color: #FFFFFF;
  border-radius: 18rpx;
  padding: 24rpx 20rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(46,139,87,0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tc-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.tc-emoji {
  font-size: 38rpx;
}

.tc-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-bottom: 6rpx;
}

.tc-desc {
  font-size: 22rpx;
  color: #5A7A5C;
  text-align: center;
  line-height: 1.4;
  margin-bottom: 10rpx;
  min-height: 32rpx;
}

.tc-footer {
  display: flex;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 12rpx;
}

.tc-price {
  font-size: 24rpx;
  font-weight: 700;
  color: #2E8B57;
}

.tc-extra {
  font-size: 20rpx;
  color: #999;
}

.tc-btn {
  width: 100%;
  font-size: 24rpx;
  padding: 12rpx 0;
  border-radius: 30rpx;
}

.tips-section {
  background-color: #FFFFFF;
  margin: 0 20rpx;
  border-radius: 18rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(46,139,87,0.05);
}

.tips-header {
  margin-bottom: 16rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.tips-grid-sm {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tip-chip {
  flex: 1;
  background-color: #E8F5E9;
  border-radius: 12rpx;
  padding: 12rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tip-chip-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.tip-chip-text {
  font-size: 18rpx;
  color: #2C3E2D;
  text-align: center;
  line-height: 1.3;
}

.tips-detail {
  background-color: #FAFBFA;
  border-radius: 10rpx;
  padding: 16rpx 18rpx;
}

.tips-detail-item {
  font-size: 24rpx;
  color: #5A7A5C;
  line-height: 1.8;
  display: block;
}
