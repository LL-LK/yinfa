<view class="transport font-mode-{{fontSizeMode}}">
  <loading-view wx:if="{{loading}}" />
  <error-view wx:elif="{{error}}" bind:retry="loadTransportModes" />

  <block wx:else>
  <banner-view icon="🚌" title="交通出行" desc="出行无忧·老人友好指南" />

  <view class="quick-btns">
    <view class="qb-btn" bindtap="callTaxi">
      <text class="qb-icon">🚕</text>
      <text class="qb-label">呼叫出租车</text>
    </view>
    <view class="qb-btn" bindtap="goTraffic">
      <text class="qb-icon">🚦</text>
      <text class="qb-label">查看路况</text>
    </view>
  </view>

  <view class="mode-list">
    <view class="mode-item" wx:for="{{modes}}" wx:key="id">
      <view class="mi-header">
        <text class="mi-icon">{{item.icon}}</text>
        <view class="mi-title-row">
          <text class="mi-name">{{item.name}}</text>
          <text class="mi-badge">{{item.suitable}}</text>
        </view>
      </view>
      <text class="mi-desc">{{item.desc}}</text>
      <text class="mi-tips">💡 {{item.tips}}</text>
    </view>
  </view>

  <view class="tips-list">
    <view class="tl-item" wx:for="{{tips}}" wx:key="index">
      <text class="tl-icon">{{item.icon}}</text>
      <text class="tl-text">{{item.text}}</text>
    </view>
  </view>
  </block>
</view>
