<view class="index">
  <view class="banner">
    <text class="banner-icon">🏞️</text>
    <view class="banner-text">
      <text class="banner-title">桂林银发旅游</text>
      <text class="banner-desc" bindtap="readAloud">舒适慢行 · 安心享受（点击听取导航提示）</text>
    </view>
  </view>

  <view class="weather-mini" bindtap="goSafety">
    <text class="w-icon">{{weather.icon}}</text>
    <text class="w-text">桂林 {{weather.condition}} {{weather.temp}}</text>
    <text class="w-arrow">查看详情 ></text>
  </view>

  <view class="modules">
    <view class="module-item" wx:for="{{modules}}" wx:key="index"
      bindtap="goModule"
      data-url="{{item.url}}" data-name="{{item.name}}" data-voice="{{item.voice}}">
      <text class="mo-icon">{{item.icon}}</text>
      <text class="mo-name">{{item.name}}</text>
    </view>
  </view>

  <view class="hot-section">
    <view class="hot-title">🔥 桂林热门推荐</view>
    <scroll-view scroll-x class="hot-scroll">
      <view class="hot-item" wx:for="{{hotProducts}}" wx:key="id" bindtap="goDetails" data-id="{{item.id}}">
        <image src="{{item.image}}" class="hot-img" mode="aspectFill" />
        <text class="hot-tag" wx:if="{{item.tag}}">{{item.tag}}</text>
        <view class="hot-info">
          <text class="hot-name">{{item.name}}</text>
          <text class="hot-price" wx:if="{{item.price}}">¥{{item.price}}</text>
          <text class="hot-price free" wx:else>免费</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="tips">
    <text class="tips-icon">💡</text>
    <text class="tips-text">桂林5月气候宜人，记得带外套和雨伞，漓江游船需提前预约</text>
  </view>

  <view class="quick-actions">
    <view class="qa-btn emergency" bindtap="sendSOS">
      <text class="qa-icon">🆘</text>
      <text class="qa-label">一键呼救</text>
    </view>
    <view class="qa-btn" bindtap="goTraffic">
      <text class="qa-icon">🚦</text>
      <text class="qa-label">实时路况</text>
    </view>
    <view class="qa-btn" bindtap="goOrders">
      <text class="qa-icon">📋</text>
      <text class="qa-label">我的订单</text>
    </view>
  </view>
</view>
