.index {
  background: var(--bg);
  padding-bottom: 40rpx;
}

.safety-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #FFF8E7 0%, #E8F5E9 40%, #E8F4FD 100%);
  background: linear-gradient(135deg, var(--gold-light) 0%, var(--primary-light) 40%, var(--water-light) 100%);
}

.safety-emoji {
  font-size: 36rpx;
}

.safety-text {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.safety-text2 {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.swiper-box {
  width: 100%;
}

.swiper {
  width: 100%;
  height: 360rpx;
}

.slide-image {
  width: 100%;
  height: 100%;
}

.swiper-label {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  background: var(--bg-overlay);
  color: var(--text-inverse);
  font-size: var(--font-xs);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-sm);
}

.module-grid {
  display: flex;
  flex-wrap: wrap;
  background: var(--bg-card);
  margin: 20rpx;
  border-radius: var(--radius-lg);
  padding: 12rpx;
  gap: 12rpx;
  box-shadow: var(--shadow-sm);
}

.function-item {
  position: relative;
  width: calc((100% - 36rpx) / 4);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 2rpx 12rpx;
  box-sizing: border-box;
  transition: all var(--transition-fast);
}

.function-item:active {
  transform: scale(0.95);
}

.function-icon-img {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 6rpx;
}

.function-name {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  line-height: var(--line-height-tight);
}

.function-sub {
  font-size: 20rpx;
  color: var(--text-hint);
  text-align: center;
  margin-top: 2rpx;
  font-weight: 500;
}

.font-mode-small .function-icon {
  font-size: 48rpx;
  margin-bottom: 4rpx;
}

.font-mode-small .function-icon-img {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.font-mode-small .function-name {
  font-size: var(--font-sm);
}

.font-mode-small .function-sub {
  font-size: 20rpx;
}

/* ---- 8个组件独立主题 ---- */

.map-themed {
  background: linear-gradient(180deg, #E3F2FD 0%, #BBDEFB 100%);
  border-radius: var(--radius-md);
  border-bottom: 4rpx solid #42A5F5;
}
.map-themed .function-name { color: #0D47A1; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }
.map-themed .function-sub { color: #1565C0; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }

.food-themed {
  background: linear-gradient(180deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: var(--radius-md);
  border-bottom: 4rpx solid #FF9800;
}
.food-themed .function-name { color: #BF360C; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }
.food-themed .function-sub { color: #E65100; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }

.transport-themed {
  background: linear-gradient(180deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: var(--radius-md);
  border-bottom: 4rpx solid #66BB6A;
}
.transport-themed .function-name { color: #1B5E20; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }
.transport-themed .function-sub { color: #2E7D32; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }

.health-themed {
  background: linear-gradient(180deg, #E0F2F1 0%, #B2DFDB 100%);
  border-radius: var(--radius-md);
  border-bottom: 4rpx solid #26A69A;
}
.health-themed .function-name { color: #004D40; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }
.health-themed .function-sub { color: #00695C; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }

.emergency-themed {
  background: linear-gradient(180deg, #FFEBEE 0%, #FFCDD2 100%);
  border-radius: var(--radius-md);
  border-bottom: 4rpx solid #EF5350;
}
.emergency-themed .function-name { color: #B71C1C; font-weight: 800; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }
.emergency-themed .function-sub { color: #C62828; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }
.sos-text { color: #B71C1C; font-weight: 700; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }

.cart-themed {
  background: linear-gradient(180deg, #F3E5F5 0%, #E1BEE7 100%);
  border-radius: var(--radius-md);
  border-bottom: 4rpx solid #AB47BC;
}
.cart-themed .function-name { color: #4A148C; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }
.cart-themed .function-sub { color: #6A1B9A; text-shadow: 0 1rpx 2rpx rgba(255,255,255,0.6); }

.traffic-themed {
  background: linear-gradient(180deg, #FFF8E1 0%, #FFECB3 100%);
  border-radius: var(--radius-md);
  border-bottom: 4rpx solid #FFC107;
}
.traffic-themed .function-name { color: #F57F17; font-weight: 700; }
.traffic-themed .function-sub { color: #E65100; font-weight: 600; }

.assistant-themed {
  background: linear-gradient(180deg, #E8EAF6 0%, #C5CAE9 100%);
  border-radius: var(--radius-md);
  border-bottom: 4rpx solid #5C6BC0;
}
.assistant-themed .function-name { color: #283593; font-weight: 700; }
.assistant-themed .function-sub { color: #1A237E; font-weight: 600; }

.hot-section {
  margin: 0 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.section-more {
  font-size: var(--font-sm);
  color: var(--primary);
  font-weight: 600;
}

.hot-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 4rpx 0;
}

.hot-item {
  width: calc(33.333% - 10rpx);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
  margin-bottom: 16rpx;
}

.hot-item:active {
  transform: scale(0.97);
  box-shadow: none;
}

.hot-image-box {
  position: relative;
  width: 100%;
  height: 180rpx;
  overflow: hidden;
  background: var(--border-light);
}

.hot-image {
  width: 100%;
  height: 100%;
}

.hot-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-xs);
  font-size: 20rpx;
  color: var(--text-inverse);
  font-weight: 600;
}

.hot-name {
  display: block;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
  padding: 14rpx 14rpx 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-bottom {
  display: flex;
  align-items: baseline;
  padding: 0 14rpx 16rpx;
}

.hot-price {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--accent);
}

.hot-sold {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-left: 4rpx;
}

.skeleton-card {
  width: calc(33.333% - 10rpx);
  height: 280rpx;
  background: var(--bg-card);
  margin-bottom: 16rpx;
}

.skeleton-card::after {
  content: '';
  display: block;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(200,200,200,0.3) 50%, transparent 100%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.5s infinite;
}

@keyframes skeleton-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.error-state, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
}

.error-icon, .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text, .empty-title {
  font-size: var(--font-md);
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.font-mode-large .module-grid {
  gap: 16rpx;
  padding: 16rpx;
}

.font-mode-large .function-item {
  width: calc((100% - 16rpx) / 2);
  padding: 24rpx 8rpx 20rpx;
}

.font-mode-large .function-icon {
  font-size: 72rpx;
  margin-bottom: 10rpx;
}

.font-mode-large .function-icon-img {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 10rpx;
}

.font-mode-large .function-name {
  font-size: var(--font-md);
}

.font-mode-large .function-sub {
  font-size: var(--font-xs);
  margin-top: 4rpx;
}