.home {
  background-color: #F5F9F6;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #1B6B3A 0%, #2E8B57 40%, #3CB371 100%);
  padding: 36rpx 30rpx 30rpx;
  position: relative;
  overflow: hidden;
}

.header-bg-decor {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.decor-dot {
  position: absolute;
  color: rgba(255,255,255,0.12);
  font-size: 48rpx;
}

.d1 { top: 16rpx; right: 60rpx; }
.d2 { top: 40rpx; right: 120rpx; font-size: 32rpx; }

.decor-ring {
  position: absolute;
  color: rgba(255,255,255,0.08);
  font-size: 80rpx;
}

.r1 { bottom: -16rpx; left: 30rpx; }
.r2 { top: 10rpx; right: 20rpx; font-size: 56rpx; }

.header-top {
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.header-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.header-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.header-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.header-sub-row {
  display: flex;
  align-items: center;
}

.header-loc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.header-divider {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  margin: 0 16rpx;
}

.header-phone {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  padding: 6rpx 16rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
}

.header-phone:active {
  background: rgba(255,255,255,0.25);
}

.swiper {
  width: 100%;
  height: 320rpx;
}

.slide-image {
  width: 100%;
  height: 100%;
}

.swiper-label {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  background: rgba(0,0,0,0.4);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.function-section {
  padding: 16rpx 12rpx;
  background-color: #FFFFFF;
  margin: 16rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(46,139,87,0.05);
}

.function-grid {
  display: flex;
  flex-wrap: wrap;
}

.function-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 4rpx;
}

.function-icon-box {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.function-emoji {
  font-size: 40rpx;
}

.function-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #2C3E2D;
  text-align: center;
  line-height: 1.2;
}

.function-desc {
  font-size: 18rpx;
  color: #5A7A5C;
  margin-top: 2rpx;
  text-align: center;
}

.weather-tip {
  margin: 0 20rpx 16rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid #C8E6C9;
}

.weather-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.weather-emoji {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.weather-info {
  display: flex;
  flex-direction: column;
}

.weather-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.weather-detail {
  font-size: 22rpx;
  color: #5A7A5C;
  margin-top: 2rpx;
}

.weather-action {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #2E8B57;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.weather-action:active {
  opacity: 0.85;
}

.weather-action-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.weather-action-arrow {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-left: 6rpx;
}

.hot-section {
  padding: 24rpx 20rpx;
  background-color: #FFFFFF;
  margin: 0 20rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(46,139,87,0.05);
}

.hot-section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.view-all {
  font-size: 24rpx;
  color: #2E8B57;
  font-weight: 600;
}

.hot-scroll {
  width: 100%;
}

.scroll-view {
  display: flex;
  white-space: nowrap;
}

.hot-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 16rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background-color: #FAFBFA;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  white-space: normal;
  vertical-align: top;
}

.hot-image-box {
  position: relative;
  width: 200rpx;
  height: 160rpx;
  overflow: hidden;
}

.hot-image {
  width: 100%;
  height: 100%;
}

.hot-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
}

.hot-info {
  padding: 12rpx;
}

.hot-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E2D;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
  margin-bottom: 6rpx;
}

.hot-price {
  display: flex;
  align-items: baseline;
}

.hot-price-symbol {
  font-size: 22rpx;
  color: #FF8C42;
  font-weight: 600;
}

.hot-price-num {
  font-size: 30rpx;
  color: #FF8C42;
  font-weight: 700;
}

.double-banner {
  display: flex;
  margin: 0 20rpx;
  gap: 16rpx;
}

.safety-banner,
.traffic-banner {
  flex: 1;
  border-radius: 16rpx;
  overflow: hidden;
}

.safety-banner {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
}

.traffic-banner {
  background: linear-gradient(135deg, #267349 0%, #2980B9 100%);
}

.safety-banner-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.sb-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.sb-text {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sb-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.sb-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 2rpx;
}
