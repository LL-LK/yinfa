.home {
  background-color: #F5F9F6;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 40rpx 30rpx;
}

.header-top {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
}

.swiper {
  width: 100%;
  height: 360rpx;
}

.slide-image {
  width: 100%;
  height: 100%;
}

.swiper-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background-color: #FF8C42;
  color: #FFFFFF;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
}

.function-section {
  padding: 30rpx 24rpx;
  background-color: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.function-grid {
  display: flex;
  flex-wrap: wrap;
}

.function-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 6rpx;
  margin-bottom: 8rpx;
}

.function-icon-box {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.function-emoji {
  font-size: 44rpx;
}

.function-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E2D;
  text-align: center;
  line-height: 1.2;
}

.function-desc {
  font-size: 20rpx;
  color: #5A7A5C;
  margin-top: 2rpx;
  text-align: center;
}

.weather-tip {
  margin: 0 24rpx 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #C8E6C9;
}

.weather-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.weather-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.weather-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.weather-detail {
  font-size: 24rpx;
  color: #5A7A5C;
  margin-top: 4rpx;
}

.hot-section {
  padding: 30rpx 24rpx;
  background-color: #FFFFFF;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.hot-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.hot-item {
  width: 48%;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #FAFBFA;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.hot-image-box {
  position: relative;
  width: 100%;
  height: 200rpx;
  overflow: hidden;
}

.hot-image {
  width: 100%;
  height: 100%;
}

.hot-tag {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.hot-info {
  padding: 16rpx 14rpx 18rpx;
}

.hot-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E2D;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 8rpx;
}

.hot-price {
  display: flex;
  align-items: baseline;
}

.hot-price-symbol {
  font-size: 24rpx;
  color: #FF8C42;
  font-weight: 600;
}

.hot-price-num {
  font-size: 34rpx;
  color: #FF8C42;
  font-weight: 700;
}

.hot-price-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

.safety-banner {
  margin: 0 24rpx 20rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  border-radius: 20rpx;
  overflow: hidden;
}

.safety-banner-content {
  display: flex;
  align-items: center;
  padding: 28rpx;
}

.safety-banner-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.safety-banner-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.safety-banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.safety-banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.safety-banner-arrow {
  font-size: 36rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 700;
}
