.index {
  background: var(--bg);
  padding-bottom: 40rpx;
}

.safety-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, var(--gold-light) 0%, var(--primary-light) 40%, var(--water-light) 100%);
}

.safety-emoji {
  font-size: 36rpx;
}

.safety-text {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.safety-text2 {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.swiper-box {
  width: 100%;
}

.swiper {
  width: 100%;
  height: 360rpx;
}

.slide-image {
  width: 100%;
  height: 100%;
}

.swiper-label {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  background: var(--bg-overlay);
  color: var(--text-inverse);
  font-size: var(--font-xs);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-sm);
}

.module-grid {
  display: flex;
  flex-wrap: wrap;
  background: var(--bg-card);
  margin: 20rpx;
  border-radius: var(--radius-lg);
  padding: 12rpx 8rpx;
  box-shadow: var(--shadow-sm);
}

.function-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 6rpx;
  transition: all var(--transition-fast);
}

.function-item:active {
  background: var(--bg-mask);
  border-radius: var(--radius-md);
}

.function-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.function-name {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  line-height: var(--line-height-tight);
}

.hot-section {
  margin: 0 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.section-more {
  font-size: var(--font-sm);
  color: var(--primary);
  font-weight: 600;
}

.hot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-item {
  width: calc(33.33% - 12rpx);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.hot-item:active {
  transform: scale(0.97);
  box-shadow: none;
}

.hot-image-box {
  position: relative;
  width: 100%;
  height: 180rpx;
  overflow: hidden;
  background: var(--border-light);
}

.hot-image {
  width: 100%;
  height: 100%;
}

.hot-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-xs);
  font-size: 20rpx;
  color: var(--text-inverse);
  font-weight: 600;
}

.hot-name {
  display: block;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
  padding: 14rpx 14rpx 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-bottom {
  display: flex;
  align-items: baseline;
  padding: 0 14rpx 16rpx;
}

.hot-price {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--accent);
}

.hot-sold {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-left: 4rpx;
}
