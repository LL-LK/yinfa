.food {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.featured {
  display: flex;
  margin: 16rpx 20rpx;
  gap: 12rpx;
}

.ft-item {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-sm);
  position: relative;
  transition: all var(--transition-fast);
}

.ft-item:active {
  background: var(--bg-hover);
  transform: scale(0.97);
}

.ft-badge {
  position: absolute;
  top: 6rpx;
  right: 8rpx;
  font-size: var(--font-xs);
  background: var(--accent);
  color: var(--text-inverse);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-pill);
  font-weight: 700;
}

.ft-name {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
}

.ft-sub {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.food-list {
  padding: 0 20rpx;
}

.food-item {
  display: flex;
  flex-wrap: wrap;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.food-item.selected {
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--accent-light);
}

.fi-img {
  width: 200rpx;
  height: 160rpx;
  flex-shrink: 0;
  background: var(--border-light);
}

.fi-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.fi-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.fi-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.fi-badge {
  font-size: var(--font-xs);
  padding: 4rpx 14rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: var(--radius-pill);
  font-weight: 600;
}

.fi-price {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--accent);
}

.fi-score {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.fi-expand {
  width: 100%;
  padding: 20rpx 24rpx;
  background: var(--bg);
  border-top: 1rpx solid var(--border-light);
  animation: foodFadeIn var(--transition-normal);
}

@keyframes foodFadeIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fi-desc {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
  margin-bottom: 12rpx;
}

.fi-addr {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-hint);
}