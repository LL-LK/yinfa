<view class="food font-mode-{{fontSizeMode}}">
  <loading-view wx:if="{{loading}}" />
  <error-view wx:elif="{{error}}" bind:retry="loadFoods" />
  <empty-view wx:elif="{{empty}}" icon="🍜" title="暂无美食推荐" desc="美食数据正在更新中，请稍后再来" />

  <block wx:else>
  <banner-view icon="🍜" title="桂林美食" desc="地道风味·老人友好推荐" />

  <view class="featured">
    <view class="ft-item" wx:for="{{featured}}" wx:key="index">
      <text class="ft-badge">{{item.badge}}</text>
      <text class="ft-name">{{item.name}}</text>
      <text class="ft-sub">{{item.sub}}</text>
    </view>
  </view>

  <view class="food-list">
    <view class="food-item {{item.expanded ? 'selected' : ''}}" wx:for="{{foods}}" wx:key="id" bindtap="selectFood" data-index="{{index}}">
      <image src="{{item.image}}" class="fi-img" mode="aspectFill" lazy-load />
      <view class="fi-info">
        <view class="fi-name-row">
          <text class="fi-name">{{item.name}}</text>
          <text class="fi-badge">{{item.type}}</text>
        </view>
        <text class="fi-price">¥{{item.price}}起</text>
        <text class="fi-score">⭐{{item.score}}</text>
      </view>
      <view class="fi-expand" wx:if="{{item.expanded}}">
        <text class="fi-desc">{{item.desc}}</text>
        <text class="fi-addr">📍 {{item.address}}</text>
      </view>
    </view>
  </view>
  </block>
</view>
