<view class="food">
  <view wx:if="{{loading}}" class="loading-spinner">
    <view class="loading-ring"></view>
  </view>

  <view wx:elif="{{error}}" class="error-state">
    <text class="error-icon">😵</text>
    <text class="error-title">加载失败</text>
    <text class="btn-primary" bindtap="loadFoods" style="margin-top:20rpx;padding:12rpx 48rpx;font-size:28rpx;min-height:64rpx;line-height:64rpx;">重新加载</text>
  </view>

  <view wx:elif="{{empty}}" class="empty-state">
    <text class="empty-icon">🍜</text>
    <text class="empty-title">暂无美食推荐</text>
    <text class="empty-desc">美食数据正在更新中，请稍后再来</text>
  </view>

  <block wx:else>
  <view class="banner">
    <text class="banner-icon">🍜</text>
    <view class="banner-text">
      <text class="banner-title">桂林美食</text>
      <text class="banner-desc">地道风味·老人友好推荐</text>
    </view>
  </view>

  <view class="featured">
    <view class="ft-item" wx:for="{{featured}}" wx:key="index">
      <text class="ft-badge">{{item.badge}}</text>
      <text class="ft-name">{{item.name}}</text>
      <text class="ft-sub">{{item.sub}}</text>
    </view>
  </view>

  <view class="food-list">
    <view class="food-item {{item.expanded ? 'selected' : ''}}" wx:for="{{foods}}" wx:key="id" bindtap="selectFood" data-index="{{index}}">
      <image src="{{item.image}}" class="fi-img" mode="aspectFill" lazy-load />
      <view class="fi-info">
        <view class="fi-name-row">
          <text class="fi-name">{{item.name}}</text>
          <text class="fi-badge">{{item.type}}</text>
        </view>
        <text class="fi-price">¥{{item.price}}起</text>
        <text class="fi-score">⭐{{item.score}}</text>
      </view>

      <view class="fi-expand" wx:if="{{item.expanded}}">
        <text class="fi-desc">{{item.desc}}</text>
        <text class="fi-addr">📍 {{item.address}}</text>
      </view>
    </view>
  </view>
  </block>
</view>
