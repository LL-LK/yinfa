.list {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 32rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-inverse);
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.filter-bar {
  display: flex;
  white-space: nowrap;
  background: var(--bg-card);
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.filter-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  margin-right: 16rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  background: var(--bg);
  transition: all var(--transition-fast);
  flex-shrink: 0;
}

.filter-item.active {
  background: var(--primary);
  color: var(--text-inverse);
  font-weight: 600;
}

.product-grid {
  padding: 20rpx;
}

.product-item {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.product-item:active {
  transform: scale(0.98);
  box-shadow: none;
}

.product-image {
  width: 220rpx;
  height: 180rpx;
  flex-shrink: 0;
  background: var(--border-light);
}

.product-img {
  width: 100%;
  height: 100%;
}

.product-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  line-height: var(--line-height-tight);
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--accent);
}

.product-tag {
  padding: 6rpx 16rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: var(--radius-pill);
  font-size: var(--font-xs);
  font-weight: 600;
}
