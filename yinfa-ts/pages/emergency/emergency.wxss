.emergency {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, var(--danger) 0%, var(--danger-dark) 100%);
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: var(--font-xxl);
  margin-right: 20rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-inverse);
}

.banner-desc {
  font-size: var(--font-xs);
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.tip-bar {
  margin: 16rpx 20rpx;
  padding: 20rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
}

.contacts-list {
  padding: 0 20rpx;
}

.contact-card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.contact-card.primary {
  border-left: 8rpx solid var(--danger);
}

.cc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.cc-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.cc-badge {
  font-size: var(--font-xs);
  padding: 6rpx 16rpx;
  background: var(--danger-light);
  color: var(--danger);
  border-radius: var(--radius-pill);
  font-weight: 700;
}

.cc-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.cc-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cc-label {
  font-size: var(--font-sm);
  color: var(--text-hint);
  width: 120rpx;
}

.cc-value {
  font-size: var(--font-lg);
  color: var(--text-primary);
  font-weight: 600;
}

.cc-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-light);
}

.cc-action {
  flex: 1;
  text-align: center;
  padding: 18rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
  transition: all var(--transition-fast);
}

.cc-action:active {
  background: var(--bg-hover);
}

.cc-action.danger {
  background: var(--danger-light);
  color: var(--danger);
}

.empty-contacts {
  text-align: center;
  padding: 100rpx 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: var(--font-lg);
  color: var(--text-hint);
}

.form-modal {
  padding: 40rpx;
}

.fm-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 32rpx;
  text-align: center;
}

.fm-item {
  margin-bottom: 24rpx;
}

.fm-label {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.fm-input {
  width: 100%;
  padding: 24rpx 20rpx;
  background: var(--bg);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: var(--font-lg);
  box-sizing: border-box;
}

.fm-btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.fm-btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  border-radius: var(--radius-md);
  font-size: var(--font-lg);
  font-weight: 700;
  transition: all var(--transition-fast);
}

.fm-btn:active {
  transform: scale(0.97);
}

.fm-btn-cancel {
  background: var(--bg);
  color: var(--text-secondary);
  border: 2rpx solid var(--border);
}

.fm-btn-confirm {
  background: var(--danger);
  color: var(--text-inverse);
}

.fm-btn-confirm:active {
  background: var(--danger-dark);
}

.add-btn {
  margin: 20rpx;
  text-align: center;
  padding: 28rpx;
  background: var(--danger);
  color: var(--text-inverse);
  font-size: var(--font-lg);
  font-weight: 700;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.add-btn:active {
  background: var(--danger-dark);
  transform: scale(0.97);
}
