.scenic {
  background: var(--bg);
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-inverse);
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.tips-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 16rpx 20rpx;
  padding: 20rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  border-left: 6rpx solid var(--accent);
}

.tips-icon {
  font-size: 36rpx;
}

.tips-text {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.scenic-list {
  padding: 0 20rpx;
}

.scenic-item {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.si-img {
  width: 100%;
  height: 300rpx;
  display: block;
}

.si-tags {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx 8rpx;
}

.si-level {
  font-size: var(--font-xs);
  font-weight: 700;
  color: var(--text-inverse);
  background: var(--accent);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
}

.si-time {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.si-price {
  font-size: var(--font-xs);
  font-weight: 700;
  color: var(--accent);
  margin-left: auto;
}

.si-elder-info {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 8rpx 24rpx 12rpx;
}

.elder-tag {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: var(--radius-pill);
  background: var(--primary-light);
  color: var(--primary-dark);
  font-weight: 600;
}

.si-info {
  padding: 0 24rpx 16rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.si-name {
  display: block;
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.si-intro {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
}

.si-expand {
  padding: 20rpx 24rpx;
  background: var(--bg);
  animation: fadeIn var(--transition-normal);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.si-section {
  margin-bottom: 18rpx;
}

.si-section:last-child {
  margin-bottom: 0;
}

.si-label {
  display: block;
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.si-val {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
}

.si-val.warn {
  background: var(--warning-light);
  padding: 16rpx;
  border-radius: var(--radius-sm);
  color: var(--warning);
  font-weight: 600;
}

.si-buy-btn {
  margin-top: 20rpx;
  text-align: center;
  padding: 24rpx;
  background: var(--primary);
  color: var(--text-inverse);
  font-size: var(--font-lg);
  font-weight: 700;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.si-buy-btn:active {
  background: var(--primary-dark);
  transform: scale(0.97);
}

.bottom-space {
  height: 40rpx;
}
