.scenic {
  background-color: #F5F9F6;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 40rpx 30rpx;
}

.banner-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.scenic-list {
  padding: 20rpx 24rpx;
}

.scenic-item {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.scenic-image {
  width: 100%;
  height: 340rpx;
}

.scenic-body {
  padding: 24rpx 28rpx;
}

.scenic-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.scenic-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.scenic-level {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.scenic-intro {
  font-size: 28rpx;
  color: #5A7A5C;
  line-height: 1.7;
  display: block;
  margin-bottom: 16rpx;
}

.scenic-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1rpx solid #E8F5E9;
  border-bottom: 1rpx solid #E8F5E9;
  margin-bottom: 20rpx;
}

.scenic-info {
  display: flex;
  flex-direction: column;
}

.scenic-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF8C42;
}

.scenic-time {
  font-size: 24rpx;
  color: #5A7A5C;
}

.slippery-warn {
  font-size: 24rpx;
  color: #FF8C42;
  font-weight: 600;
}

.scenic-btn {
  width: 100%;
  font-size: 32rpx;
}
