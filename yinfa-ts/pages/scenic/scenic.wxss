.scenic {
  background-color: #F5F9F6;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon-deco {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.scenic-list {
  padding: 16rpx 20rpx;
}

.scenic-item {
  background-color: #FFFFFF;
  border-radius: 18rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(46,139,87,0.05);
}

.scenic-image {
  width: 100%;
  height: 280rpx;
}

.scenic-body {
  padding: 20rpx 24rpx 12rpx;
}

.scenic-row1 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.scenic-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.scenic-level {
  font-size: 20rpx;
  padding: 2rpx 14rpx;
  border-radius: 4rpx;
}

.scenic-intro {
  font-size: 26rpx;
  color: #5A7A5C;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.scenic-row3 {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #E8F5E9;
}

.scenic-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF8C42;
}

.scenic-time {
  font-size: 22rpx;
  color: #5A7A5C;
}

.slippery-warn {
  font-size: 22rpx;
  color: #FF8C42;
  font-weight: 600;
}

.scenic-toggle {
  text-align: center;
  padding-top: 14rpx;
}

.scenic-toggle text {
  font-size: 24rpx;
  color: #2E8B57;
  font-weight: 600;
}

.scenic-extra {
  padding: 0 24rpx 20rpx;
}

.extra-card {
  background-color: #FAFBFA;
  border-radius: 10rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 10rpx;
}

.extra-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #2C3E2D;
  display: block;
  margin-bottom: 6rpx;
}

.label-warn {
  color: #FF8C42;
}

.extra-text {
  font-size: 24rpx;
  color: #5A7A5C;
  line-height: 1.7;
}

.scenic-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 6rpx;
}

.scenic-action-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 16rpx 0;
  text-align: center;
  border-radius: 30rpx;
}
