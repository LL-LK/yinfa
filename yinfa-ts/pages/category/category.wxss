.category {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: var(--font-xl);
  margin-right: 20rpx;
}

.banner-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-inverse);
}

.banner-desc {
  font-size: var(--font-xs);
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.category-body {
  display: flex;
  height: calc(100vh - 160rpx);
}

.sidebar {
  width: 200rpx;
  background: var(--bg-card);
  flex-shrink: 0;
}

.sidebar-item {
  padding: 36rpx 20rpx;
  font-size: var(--font-md);
  color: var(--text-secondary);
  text-align: center;
  border-left: 6rpx solid transparent;
  transition: all var(--transition-fast);
}

.sidebar-item.active {
  background: var(--bg);
  color: var(--primary);
  font-weight: 700;
  border-left-color: var(--primary);
  font-size: var(--font-lg);
}

.product-content {
  flex: 1;
  background: var(--bg);
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
}

.product-item {
  width: 50%;
  padding: 12rpx;
  box-sizing: border-box;
}

.product-image {
  width: 100%;
  height: 240rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--border-light);
}

.product-img {
  width: 100%;
  height: 100%;
}

.product-name {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 12rpx;
  padding: 0 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--accent);
  padding: 4rpx 8rpx 0;
}
