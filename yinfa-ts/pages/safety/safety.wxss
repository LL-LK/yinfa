.safety {
  background-color: #F5F9F6;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 36rpx 30rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
  display: block;
}

.safety-top-row {
  display: flex;
  margin: 16rpx 20rpx;
  gap: 16rpx;
}

.weather-card-compact {
  flex: 1;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #C8E6C9;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wc-top {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.wc-emoji {
  font-size: 56rpx;
}

.wc-temp {
  font-size: 40rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.wc-cond {
  font-size: 24rpx;
  color: #5A7A5C;
  margin: 4rpx 0 8rpx;
}

.wc-stats {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  color: #5A7A5C;
  margin-bottom: 6rpx;
}

.wc-road {
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  background: #FFFFFF;
  border-radius: 10rpx;
}

.text-red { color: #D32F2F; }
.text-orange { color: #FF8C42; }
.text-green { color: #2E8B57; }

.level-card {
  width: 160rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.level-safe { background: linear-gradient(135deg, #C8E6C9, #A5D6A7); }
.level-warn { background: linear-gradient(135deg, #FFF3E0, #FFE0B2); }
.level-danger { background: linear-gradient(135deg, #FFEBEE, #FFCDD2); }

.level-num-big {
  font-size: 64rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.level-word {
  font-size: 24rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-top: 4rpx;
}

.level-bar {
  display: flex;
  margin: 0 20rpx;
  gap: 4rpx;
}

.level-bar view {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  border-radius: 8rpx 8rpx 0 0;
  font-size: 22rpx;
  background: #EEE;
  color: #999;
}

.bar-safe.bar-active { background: #C8E6C9; color: #2E8B57; font-weight: 700; }
.bar-warn.bar-active { background: #FFE0B2; color: #FF8C42; font-weight: 700; }
.bar-danger.bar-active { background: #FFCDD2; color: #D32F2F; font-weight: 700; }

.level-detail-text {
  font-size: 24rpx;
  color: #5A7A5C;
  padding: 12rpx 20rpx 4rpx;
  line-height: 1.6;
  text-align: center;
}

.scenic-warnings {
  margin: 0 20rpx 16rpx;
}

.sw-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #FF8C42;
}

.sw-scroll {
  display: flex;
  white-space: nowrap;
}

.sw-chip {
  display: inline-block;
  width: 240rpx;
  border-radius: 14rpx;
  padding: 16rpx 18rpx;
  margin-right: 14rpx;
  white-space: normal;
  vertical-align: top;
}

.chip-red { background: #FFF5F5; border: 1rpx solid #FFCDD2; }
.chip-orange { background: #FFF8F0; border: 1rpx solid #FFE0B2; }
.chip-green { background: #FAFBFA; border: 1rpx solid #E8F5E9; }

.sw-chip-icon {
  font-size: 24rpx;
  display: block;
  margin-bottom: 6rpx;
}

.sw-chip-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #2C3E2D;
  display: block;
  margin-bottom: 4rpx;
}

.sw-chip-desc {
  font-size: 22rpx;
  color: #5A7A5C;
  line-height: 1.5;
}

.tips-section {
  background: #FFFFFF;
  margin: 0 20rpx 16rpx;
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(46,139,87,0.04);
}

.tips-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-bottom: 14rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #2E8B57;
}

.tips-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.tip-box {
  width: 32%;
  background: #FAFBFA;
  border-radius: 12rpx;
  padding: 16rpx 10rpx 14rpx;
  margin-bottom: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tip-box-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.tip-box-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-bottom: 4rpx;
}

.tip-box-desc {
  font-size: 20rpx;
  color: #5A7A5C;
  text-align: center;
  line-height: 1.4;
}

.accident-section {
  background: #FFFFFF;
  margin: 0 20rpx;
  border-radius: 16rpx;
  padding: 20rpx 18rpx;
  box-shadow: 0 2rpx 10rpx rgba(46,139,87,0.04);
}

.acc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-bottom: 14rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #D32F2F;
}

.acc-item {
  background: #FAFBFA;
  border-radius: 10rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 8rpx;
}

.acc-item:last-child {
  margin-bottom: 0;
}

.acc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.acc-scene {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.acc-risk {
  font-size: 20rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  background: #FFF;
  border-radius: 6rpx;
}

.acc-prevent {
  font-size: 24rpx;
  color: #5A7A5C;
  line-height: 1.6;
}
