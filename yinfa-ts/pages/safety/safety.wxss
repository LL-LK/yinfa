.safety {
  background: var(--bg);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.poster-section {
  position: relative;
  width: 100%;
  min-height: 200rpx;
  background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 40%, #43A047 100%);
}

.poster-img {
  width: 100%;
  display: block;
  min-height: 200rpx;
}

.poster-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 32rpx 28rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.55));
}

.poster-title {
  display: block;
  font-size: var(--font-xl);
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.poster-subtitle {
  display: block;
  font-size: var(--font-sm);
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
}

.safety-scroll {
  flex: 1;
  height: calc(100vh - 400rpx);
}

.section-card {
  margin: 0 20rpx 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow-sm);
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--border-light);
}

.card-icon {
  font-size: var(--font-xl);
}

.card-title-text {
  flex: 1;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.refresh-btn {
  font-size: var(--font-xs);
  color: var(--primary);
  font-weight: 600;
  padding: 6rpx 16rpx;
  background: var(--primary-light);
  border-radius: var(--radius-pill);
}

.weather-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.wg-item {
  background: var(--cloud);
  border-radius: var(--radius-md);
  padding: 18rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.wg-item.wg-highlight {
  grid-column: span 2;
  background: linear-gradient(135deg, var(--gold-light) 0%, #FFECB3 100%);
  border: 2rpx solid #FFE082;
}

.wg-label {
  font-size: var(--font-xs);
  color: var(--text-hint);
  font-weight: 600;
}

.wg-value {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
}

.wg-value.road-1 { color: var(--success); }
.wg-value.road-2 { color: var(--warning); }
.wg-value.road-3 { color: var(--sos); }

.advice-main-box {
  background: linear-gradient(135deg, var(--gold-light) 0%, #FFF9C4 100%);
  border-radius: var(--radius-md);
  padding: 18rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid var(--warning);
}

.advice-main {
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: var(--line-height-relaxed);
  font-weight: 500;
}

.advice-cols {
  display: flex;
  gap: 12rpx;
}

.advice-col {
  flex: 1;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.col-ok {
  background: linear-gradient(135deg, var(--success-light) 0%, var(--accent-light) 100%);
  border: 2rpx solid #A5D6A7;
}

.col-no {
  background: linear-gradient(135deg, var(--sos-light) 0%, #FFCDD2 100%);
  border: 2rpx solid #EF9A9A;
}

.col-head {
  padding: 14rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(255, 255, 255, 0.5);
}

.col-ic { font-size: var(--font-sm); }
.col-tit { font-size: var(--font-xs); font-weight: 700; color: var(--text-primary); }

.col-body {
  padding: 14rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.col-item {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 500;
  padding-left: 14rpx;
  position: relative;
}

.col-item::before {
  content: '•';
  position: absolute;
  left: 0;
  color: #9E9E9E;
  font-weight: 700;
}

.emergency-section {
  display: flex;
  gap: 14rpx;
  margin: 0 20rpx 20rpx;
}

.em-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 28rpx 16rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md), inset 0 2rpx 4rpx rgba(255,255,255,0.2);
  transition: all var(--transition-fast);
  border: 2rpx solid transparent;
}

.em-btn:active {
  transform: scale(0.95);
}

.sos-em-btn {
  background: linear-gradient(135deg, var(--sos-dark) 0%, var(--sos) 100%);
  box-shadow: var(--shadow-sos), inset 0 2rpx 4rpx rgba(255,255,255,0.15);
}

.loc-em-btn {
  background: linear-gradient(135deg, var(--water-dark) 0%, #42A5F5 100%);
}

.contact-em-btn {
  background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
}

.em-icon {
  font-size: var(--font-xxl);
}

.em-text {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--text-inverse);
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 16rpx;
  background: var(--bg);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.tip-item:active {
  background: var(--primary-light);
}

.tip-level {
  font-size: var(--font-xl);
  width: 48rpx;
  text-align: center;
  flex-shrink: 0;
  line-height: 1;
}

.tip-high { color: var(--sos); }
.tip-medium { color: var(--warning); }
.tip-low { color: var(--success); }

.tip-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.tip-name {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--text-primary);
}

.tip-desc {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: var(--line-height-relaxed);
}

.health-tips {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ht-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  background: var(--success-light);
  border-radius: var(--radius-sm);
  border-left: 4rpx solid var(--success);
}

.ht-icon {
  font-size: var(--font-lg);
  flex-shrink: 0;
}

.ht-text {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 500;
  line-height: var(--line-height-relaxed);
}

.bottom-space {
  height: 40rpx;
}