.safety {
  background-color: #F5F9F6;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 40rpx 30rpx;
}

.banner-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.weather-card {
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid #C8E6C9;
}

.weather-status {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.weather-emoji {
  font-size: 80rpx;
  margin-right: 24rpx;
}

.weather-info {
  display: flex;
  flex-direction: column;
}

.weather-temp {
  font-size: 48rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.weather-condition {
  font-size: 28rpx;
  color: #5A7A5C;
  margin-top: 4rpx;
}

.weather-location {
  font-size: 24rpx;
  color: #5A7A5C;
  margin-top: 2rpx;
}

.weather-details {
  display: flex;
  justify-content: space-around;
}

.weather-detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-label {
  font-size: 24rpx;
  color: #5A7A5C;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C3E2D;
  margin-top: 4rpx;
}

.text-red { color: #D32F2F; }
.text-orange { color: #FF8C42; }
.text-green { color: #2E8B57; }

.slippery-level {
  background-color: #FFFFFF;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.level-display {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.level-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.level-safe {
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
}

.level-warn {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

.level-danger {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
}

.level-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.level-text {
  display: flex;
  flex-direction: column;
}

.level-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.level-desc {
  font-size: 26rpx;
  color: #5A7A5C;
  margin-top: 6rpx;
  line-height: 1.5;
}

.level-indicators {
  display: flex;
  justify-content: space-around;
}

.indicator {
  padding: 10rpx 40rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  background-color: #F5F5F5;
  color: #999;
}

.indicator.active.safe {
  background-color: #E8F5E9;
  color: #2E8B57;
  font-weight: 700;
}

.indicator.active.warn {
  background-color: #FFF3E0;
  color: #FF8C42;
  font-weight: 700;
}

.indicator.active.danger {
  background-color: #FFEBEE;
  color: #D32F2F;
  font-weight: 700;
}

.scenic-warnings {
  background-color: #FFFFFF;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.warning-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.warning-high {
  background-color: #FFF5F5;
  border: 1rpx solid #FFCDD2;
}

.warning-medium {
  background-color: #FFF8F0;
  border: 1rpx solid #FFE0B2;
}

.warning-low {
  background-color: #FAFBFA;
  border: 1rpx solid #E8F5E9;
}

.warning-status {
  margin-right: 16rpx;
}

.warning-icon {
  font-size: 36rpx;
}

.warning-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.warning-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E2D;
}

.warning-desc {
  font-size: 24rpx;
  color: #5A7A5C;
  margin-top: 4rpx;
}

.warning-arrow {
  font-size: 32rpx;
  color: #CCC;
}

.tips-section {
  background-color: #FFFFFF;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(46,139,87,0.06);
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding: 20rpx;
  background-color: #FAFBFA;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tip-content {
  display: flex;
  flex-direction: column;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C3E2D;
}

.tip-desc {
  font-size: 26rpx;
  color: #5A7A5C;
  margin-top: 6rpx;
  line-height: 1.5;
}
