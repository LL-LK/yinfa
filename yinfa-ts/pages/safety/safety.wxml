<view class="safety">
  <view class="banner" bindtap="readWeather">
    <text class="banner-icon">{{weather.icon}}</text>
    <view class="banner-text">
      <text class="banner-title">{{weather.condition}} {{weather.temp}}</text>
      <text class="banner-desc">湿度{{weather.humidity}} · {{weather.wind}} · 点击播报天气</text>
    </view>
  </view>

  <view class="slip-bar">
    <view class="s-slip level-{{slippery.level}}">
      <text class="s-icon">⚠️</text>
      <text class="s-title">{{slippery.title}}</text>
      <text class="s-pic">{{slippery.desc}}</text>
    </view>
  </view>

  <view class="sos-row">
    <view class="sos-card" bindtap="callEmergency">
      <text class="sos-icon">🚑</text>
      <text class="sos-title">急救电话</text>
      <text class="sos-sub">拨打 120</text>
    </view>
    <view class="sos-card" bindtap="shareLocation">
      <text class="sos-icon">📍</text>
      <text class="sos-title">分享位置</text>
      <text class="sos-sub">发给家人</text>
    </view>
    <view class="sos-card" bindtap="goScenicTips">
      <text class="sos-icon">⚠️</text>
      <text class="sos-title">景点安全</text>
      <text class="sos-sub">出行提示</text>
    </view>
  </view>

  <view class="warn-list">
    <view class="wl-title">⚠️ 各景点路面提醒</view>
    <view class="wl-item level-{{item.level}}" wx:for="{{warnings}}" wx:key="index">
      <view class="wli-title">
        <text class="wli-dot level-{{item.level}}"></text>
        <text class="wli-name">{{item.name}}</text>
        <text class="wli-tag level-{{item.level}}" wx:if="{{item.level === 'high'}}">⚠️危险</text>
        <text class="wli-tag level-{{item.level}}" wx:else>注意</text>
      </view>
      <text class="wli-desc">{{item.desc}}</text>
    </view>
  </view>

  <view class="bottom-space"></view>
</view>
