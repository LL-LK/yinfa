<view class="safety font-mode-{{fontSizeMode}}">
  <!-- 海报区域：WebP → JPG → CSS渐变 三层降级 -->
  <view class="poster-section">
    <image src="{{posterSrc}}" class="poster-img" mode="widthFix" show-menu-by-longpress binderror="onPosterError" lazy-load />
    <view class="poster-overlay">
      <text class="poster-title">桂林·银发安全防护</text>
      <text class="poster-subtitle">出行安全 · 健康守护</text>
    </view>
  </view>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="safety-scroll">
    <!-- 天气与路况 -->
    <view class="section-card weather-card">
      <view class="card-title-row">
        <text class="card-icon">🌤️</text>
        <text class="card-title-text">今日天气 · 路面状况</text>
        <text class="refresh-btn" bindtap="loadWeather">刷新</text>
      </view>
      <view class="weather-grid">
        <view class="wg-item">
          <text class="wg-label">天气</text>
          <text class="wg-value">{{weather.condition || '--'}} {{weather.temp || '--'}}</text>
        </view>
        <view class="wg-item">
          <text class="wg-label">湿度</text>
          <text class="wg-value">{{weather.humidity || '--'}}</text>
        </view>
        <view class="wg-item">
          <text class="wg-label">风力</text>
          <text class="wg-value">{{weather.wind || '--'}}</text>
        </view>
        <view class="wg-item wg-highlight">
          <text class="wg-label">路面</text>
          <text class="wg-value road-{{slippery.level}}">{{slippery.title || '--'}}</text>
        </view>
      </view>
    </view>

    <!-- 出行建议 -->
    <view class="section-card advice-card">
      <view class="card-title-row">
        <text class="card-icon">💡</text>
        <text class="card-title-text">今日出行建议</text>
      </view>
      <view class="advice-main-box">
        <text class="advice-main">{{travelAdvice.advice || '今日天气适宜外出游览，建议携带遮阳用品和饮用水。'}}</text>
      </view>
      <view class="advice-cols">
        <view class="advice-col col-ok">
          <view class="col-head"><text class="col-ic">✅</text><text class="col-tit">推荐游览</text></view>
          <view class="col-body">
            <text class="col-item" wx:for="{{travelAdvice.suitable}}" wx:key="*this" wx:for-item="spot">{{spot}}</text>
          </view>
        </view>
        <view class="advice-col col-no">
          <view class="col-head"><text class="col-ic">❌</text><text class="col-tit">建议避开</text></view>
          <view class="col-body">
            <text class="col-item" wx:for="{{travelAdvice.avoid}}" wx:key="*this" wx:for-item="spot">{{spot}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 紧急操作 -->
    <view class="emergency-section">
      <view class="em-btn sos-em-btn" bindtap="callEmergency">
        <text class="em-icon">🆘</text>
        <text class="em-text">一键呼救</text>
      </view>
      <view class="em-btn loc-em-btn" bindtap="shareLocation">
        <text class="em-icon">📍</text>
        <text class="em-text">分享位置</text>
      </view>
      <view class="em-btn contact-em-btn" bindtap="goEmergency">
        <text class="em-icon">📞</text>
        <text class="em-text">紧急联系人</text>
      </view>
    </view>

    <!-- 安全提示 -->
    <view class="section-card tips-card">
      <view class="card-title-row">
        <text class="card-icon">⚠️</text>
        <text class="card-title-text">银发出行安全提示</text>
      </view>
      <view class="tips-list">
        <view class="tip-item" wx:for="{{safetyTips}}" wx:key="index" bindtap="readTip" data-index="{{index}}">
          <text class="tip-level tip-{{item.level}}">{{item.icon}}</text>
          <view class="tip-content">
            <text class="tip-name">{{item.name}}</text>
            <text class="tip-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 健康提醒 -->
    <view class="section-card health-card">
      <view class="card-title-row">
        <text class="card-icon">💚</text>
        <text class="card-title-text">今日健康提醒</text>
      </view>
      <view class="health-tips">
        <view class="ht-item" wx:for="{{healthTips}}" wx:key="index">
          <text class="ht-icon">{{item.icon}}</text>
          <text class="ht-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>
</view>