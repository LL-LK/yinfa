.search-page {
  background: var(--bg);
  min-height: 100vh;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: var(--space-md) var(--space-lg);
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-light);
}

.search-input-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: var(--radius-pill);
  padding: 14rpx 20rpx;
  border: 2rpx solid var(--border);
  transition: all var(--transition-fast);
}

.search-input-box.focus {
  border-color: var(--primary);
}

.search-icon {
  font-size: var(--font-lg);
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: var(--font-lg);
  color: var(--text-primary);
  background: transparent;
}

.search-clear {
  padding: 6rpx 14rpx;
  font-size: var(--font-md);
  color: var(--text-hint);
}

.search-btn {
  padding: 18rpx 32rpx;
  background: var(--primary);
  color: var(--text-inverse);
  border-radius: var(--radius-pill);
  font-size: var(--font-md);
  font-weight: 700;
}

.hot-search {
  padding: 24rpx var(--space-lg);
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-light);
}

.hot-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.hot-tag {
  padding: 14rpx 24rpx;
  background: var(--bg);
  border-radius: var(--radius-pill);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  border: 1rpx solid var(--border);
  transition: all var(--transition-fast);
}

.hot-tag:active {
  background: var(--primary-light);
  color: var(--primary);
  border-color: var(--primary);
}

.result-count {
  padding: 20rpx var(--space-lg);
  font-size: var(--font-sm);
  color: var(--text-hint);
  background: var(--bg);
}

.product-list {
  padding: 20rpx;
}

.product-item {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.product-item:active {
  transform: scale(0.98);
  box-shadow: none;
}

.product-image {
  width: 220rpx;
  height: 180rpx;
  flex-shrink: 0;
  background: var(--border-light);
}

.product-img {
  width: 100%;
  height: 100%;
}

.product-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  line-height: var(--line-height-tight);
}

.product-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--accent);
}

.product-tag {
  padding: 6rpx 16rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: var(--radius-pill);
  font-size: var(--font-xs);
  font-weight: 600;
}

.search-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.search-hint text {
  color: var(--text-hint);
}
