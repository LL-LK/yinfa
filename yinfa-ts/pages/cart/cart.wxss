.cart {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 160rpx;
}

.cart-list {
  padding: 0 20rpx;
}

.cart-item {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
  align-items: center;
  transition: all var(--transition-fast);
}

.cart-image {
  width: 140rpx;
  height: 140rpx;
  flex-shrink: 0;
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-right: var(--space-md);
}

.cart-img {
  width: 100%;
  height: 100%;
}

.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.cart-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-price {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--accent);
  display: block;
  margin-bottom: 12rpx;
}

.cart-quantity {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-xl);
  color: var(--text-secondary);
  font-weight: 700;
  transition: all var(--transition-fast);
}

.qty-btn:active {
  background: var(--primary-light);
  color: var(--primary);
}

.qty-value {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  min-width: 40rpx;
  text-align: center;
}

.cart-remove {
  font-size: var(--font-xs);
  color: var(--text-hint);
  padding: 8rpx 16rpx;
  margin-left: 16rpx;
}

.cart-remove:active {
  color: var(--sos);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 16rpx var(--shadow-color);
  z-index: 100;
}

.total-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.total-label {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-bottom: 4rpx;
}

.total-price {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--accent);
}

.checkout-btn {
  padding: 22rpx 48rpx;
  border-radius: var(--radius-pill);
  background: var(--btn-primary-bg, linear-gradient(135deg, #2E7D32, #388E3C));
  color: var(--text-inverse);
  font-size: var(--font-lg);
  font-weight: 700;
  box-shadow: var(--btn-shadow, 0 8rpx 24rpx rgba(46, 125, 50, 0.35));
  transition: all var(--transition-fast);
}

.checkout-btn:active {
  transform: scale(0.96);
}

.checkout-btn[disabled] {
  background: var(--disabled-bg, #C8E6C9);
  color: var(--text-hint);
  box-shadow: none;
}