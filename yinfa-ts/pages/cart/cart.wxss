.cart {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.banner {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
}

.banner-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-inverse);
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.cart-list {
  padding: 20rpx;
}

.cart-item {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  padding: 20rpx;
  gap: 20rpx;
}

.ci-image {
  width: 180rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--border-light);
}

.ci-img {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-sm);
}

.ci-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.ci-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ci-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ci-price {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--accent);
}

.ci-quantity {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ci-qty-btn {
  width: 56rpx;
  height: 56rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-round);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  background: var(--bg);
  transition: all var(--transition-fast);
}

.ci-qty-btn:active {
  background: var(--bg-hover);
  border-color: var(--primary);
}

.ci-qty-val {
  width: 60rpx;
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.ci-delete {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--danger-light);
  color: var(--danger);
  border-radius: var(--radius-round);
  font-size: var(--font-xs);
}

.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: var(--font-lg);
  color: var(--text-hint);
  margin-bottom: 16rpx;
}

.empty-btn {
  padding: 20rpx 60rpx;
  background: var(--primary);
  color: var(--text-inverse);
  font-size: var(--font-lg);
  font-weight: 700;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.empty-btn:active {
  background: var(--primary-dark);
  transform: scale(0.97);
}

.cart-summary {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg);
  padding-bottom: calc(var(--space-lg) + env(safe-area-inset-bottom));
  background: var(--bg-card);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.cs-total {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.cs-total-label {
  font-size: var(--font-md);
  color: var(--text-secondary);
}

.cs-total-price {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--accent);
}

.cs-checkout {
  padding: 24rpx 60rpx;
  background: var(--primary);
  color: var(--text-inverse);
  font-size: var(--font-lg);
  font-weight: 700;
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.cs-checkout:active {
  background: var(--primary-dark);
  transform: scale(0.97);
}
